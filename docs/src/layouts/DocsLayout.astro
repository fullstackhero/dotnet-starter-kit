---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/shell/Header.astro';
import Footer from '../components/shell/Footer.astro';
import Sidebar from '../components/docs/Sidebar.astro';
import TableOfContents from '../components/docs/TableOfContents.astro';
import SponsorCard from '../components/docs/SponsorCard.astro';
import { sections } from '../content/docs/_sections';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description: string;
  headings: MarkdownHeading[];
  image?: string;
  /** Per-page <title> override; falls through to BaseLayout default. */
  seoTitle?: string;
  /** Block search-engine indexing for this page (drafts, legal, etc.). */
  noindex?: boolean;
  /** Additional JSON-LD schemas (BreadcrumbList, TechArticle, …). */
  additionalSchemas?: unknown[];
}

const { title, description, headings, image, seoTitle, noindex, additionalSchemas } = Astro.props;

// Identify the current docs section for the mobile trigger label.
const pathname = new URL(Astro.request.url).pathname;
const docsMatch = pathname.match(/^\/docs\/([^/]+)/);
const currentSectionDir = docsMatch?.[1];
const currentSection = currentSectionDir
  ? sections.find((s) => s.dir === currentSectionDir)
  : undefined;
---
<BaseLayout {title} {description} {image} {seoTitle} {noindex} {additionalSchemas}>
  <Header />
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-[16rem_minmax(0,1fr)_14rem] lg:gap-10 xl:gap-12">
      <aside class="no-scrollbar fsh-edge-fade hidden lg:sticky lg:top-20 lg:block lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto lg:py-8 lg:pr-1">
        <Sidebar />
      </aside>
      <main id="main" class="min-w-0 py-6 lg:py-12">
        {/* Mobile docs nav trigger — opens slide-up sheet (hidden on lg+) */}
        <div class="mb-6 lg:hidden">
          <button
            type="button"
            data-docs-mobile-toggle
            aria-controls="docs-mobile-sheet"
            aria-expanded="false"
            aria-haspopup="dialog"
            class="group flex w-full items-center justify-between gap-3 rounded-xl border border-border bg-card px-3.5 py-3 text-left transition-colors hover:border-border-strong"
          >
            <span class="flex min-w-0 items-center gap-3">
              <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-foreground/[0.05]">
                <svg class="h-4 w-4 text-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="3" y1="6"  x2="3" y2="6.01" />
                  <line x1="3" y1="12" x2="3" y2="12.01" />
                  <line x1="3" y1="18" x2="3" y2="18.01" />
                  <line x1="8" y1="6"  x2="21" y2="6" />
                  <line x1="8" y1="12" x2="21" y2="12" />
                  <line x1="8" y1="18" x2="15" y2="18" />
                </svg>
              </span>
              <span class="flex min-w-0 flex-col gap-0.5">
                <span class="font-mono text-[9.5px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                  Browse docs
                </span>
                <span class="truncate text-[13.5px] font-semibold tracking-tight text-foreground">
                  {currentSection?.label ?? 'All sections'}
                </span>
              </span>
            </span>
            <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-muted-foreground transition-transform group-hover:translate-y-0.5">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </button>
        </div>

        <slot />
      </main>
      <aside class="hidden xl:sticky xl:top-20 xl:block xl:max-h-[calc(100vh-6rem)] xl:overflow-y-auto xl:py-8">
        <SponsorCard />
        <TableOfContents {headings} />
      </aside>
    </div>
  </div>

  {/* Mobile docs sheet — slide-up bottom sheet with the full sidebar */}
  <div
    id="docs-mobile-sheet"
    class="docs-mobile-sheet fixed inset-0 z-modal pointer-events-none lg:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Docs sections"
    data-docs-mobile-sheet
    data-open="false"
    inert
  >
    <div
      class="docs-sheet-scrim absolute inset-0 bg-foreground/40 backdrop-blur-sm"
      data-docs-mobile-close
      aria-hidden="true"
    ></div>
    <div class="docs-sheet-panel absolute inset-x-0 bottom-0 flex max-h-[88vh] flex-col rounded-t-2xl border-t border-border bg-card shadow-2xl">
      {/* Drag handle */}
      <div class="flex justify-center pt-2.5" data-docs-mobile-close>
        <span class="h-1 w-10 rounded-full bg-border-strong" aria-hidden="true"></span>
      </div>
      {/* Sheet header */}
      <div class="flex items-center justify-between px-5 pt-3 pb-4">
        <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
          Browse docs
        </span>
        <button
          type="button"
          data-docs-mobile-close
          aria-label="Close docs navigation"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border text-foreground hover:border-border-strong"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      {/* Sidebar inside sheet (auto-scrolls active item into view via existing accordion logic) */}
      <div class="no-scrollbar flex-1 overflow-y-auto px-4 pb-8" data-docs-mobile-scroll>
        <Sidebar prefix="fsh-m" />
      </div>
    </div>
  </div>

  <Footer />

  {/* Page view beacon — POSTs current slug, renders count into PageHeader. */}
  <script>
    import '../scripts/views-counter';
  </script>
</BaseLayout>

<style>
  /* Slide-up bottom sheet — modern app affordance.
     The panel translates from below-viewport to flush-bottom, scrim fades
     in alongside. inert + pointer-events gates the closed state from any
     accidental focus / scroll capture. */
  .docs-mobile-sheet[data-open="true"] {
    pointer-events: auto;
  }
  .docs-sheet-scrim {
    opacity: 0;
    transition: opacity 280ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .docs-sheet-panel {
    transform: translateY(100%);
    transition: transform 380ms cubic-bezier(0.32, 0.72, 0, 1);
    will-change: transform;
  }
  .docs-mobile-sheet[data-open="true"] .docs-sheet-scrim {
    opacity: 1;
  }
  .docs-mobile-sheet[data-open="true"] .docs-sheet-panel {
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .docs-sheet-scrim,
    .docs-sheet-panel { transition: none !important; }
  }
</style>

<script>
  // Slide-up sheet wiring: open/close, ESC, scrim, link-click auto-close,
  // body scroll lock. Idempotent — survives Astro view-transitions.
  (() => {
    const init = () => {
      const sheet = document.querySelector<HTMLElement>('[data-docs-mobile-sheet]');
      const toggle = document.querySelector<HTMLButtonElement>('[data-docs-mobile-toggle]');
      if (!sheet || !toggle) return;
      if (sheet.dataset.fshBound === '1') return;
      sheet.dataset.fshBound = '1';

      const closers = sheet.querySelectorAll<HTMLElement>('[data-docs-mobile-close]');

      const open = () => {
        sheet.dataset.open = 'true';
        sheet.inert = false;
        toggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';

        // Scroll the active link into view inside the sheet.
        requestAnimationFrame(() => {
          const active = sheet.querySelector<HTMLElement>('[aria-current="page"]');
          active?.scrollIntoView({ block: 'center', behavior: 'auto' });
        });
      };

      const close = () => {
        const wasOpen = sheet.dataset.open === 'true';
        sheet.dataset.open = 'false';
        sheet.inert = true;
        toggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        if (wasOpen) toggle.focus();
      };

      toggle.addEventListener('click', open);
      closers.forEach((c) => c.addEventListener('click', close));

      // Tap any link inside the sheet → close (so the page change feels native)
      sheet.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement | null)?.closest('a[href]');
        if (link) close();
      });

      // ESC closes
      const onKey = (e: KeyboardEvent) => {
        if (e.key === 'Escape' && sheet.dataset.open === 'true') close();
      };
      document.addEventListener('keydown', onKey);
    };

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
