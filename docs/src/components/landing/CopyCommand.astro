---
interface Props {
  command: string;
  label?: string;
}
const { command, label } = Astro.props;
const id = `cc-${Math.random().toString(36).slice(2, 9)}`;
---
<div class="group relative inline-flex w-full items-center gap-3 rounded-lg border border-border bg-card/80 px-4 py-2.5 font-mono text-[13px] text-foreground backdrop-blur-sm transition-colors hover:border-border-strong sm:w-auto sm:max-w-full">
  {label && <span class="hidden text-muted-foreground sm:inline" aria-hidden="true">{label}</span>}
  <span class="select-all overflow-x-auto whitespace-nowrap" id={`${id}-cmd`}>{command}</span>
  <button
    type="button"
    data-copy-target={id}
    aria-label="Copy command"
    class="ml-auto inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
  >
    <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="9" y="9" width="13" height="13" rx="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>
    <svg class="check-icon hidden text-success" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="20 6 9 17 4 12"></polyline>
    </svg>
  </button>
</div>

<script is:inline define:vars={{ id }}>
  (() => {
    const btn = document.querySelector(`[data-copy-target="${id}"]`);
    const cmd = document.getElementById(`${id}-cmd`);
    if (!btn || !cmd) return;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(cmd.textContent || '');
        const copy = btn.querySelector('.copy-icon');
        const check = btn.querySelector('.check-icon');
        if (copy && check) {
          copy.classList.add('hidden');
          check.classList.remove('hidden');
          setTimeout(() => {
            copy.classList.remove('hidden');
            check.classList.add('hidden');
          }, 1500);
        }
      } catch {
        /* clipboard blocked */
      }
    });
  })();
</script>
