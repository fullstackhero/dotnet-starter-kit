---
import { Icon } from 'astro-icon/components';
import SectionEyebrow from './SectionEyebrow.astro';

const modules = [
  {
    name: 'Identity',
    icon: 'lucide:shield-check',
    tagline: 'Auth that gets out of your way.',
    bullets: [
      'JWT bearer + refresh tokens',
      'ASP.NET Identity with roles + permissions',
      'Operator impersonation with audit trail',
      'Rate-limited login, register & password reset',
    ],
    snippet: `endpoints.MapPost("/users", handler)\n  .RequirePermission(Permissions.Users.Create);`,
    href: '/docs/modules/identity/',
  },
  {
    name: 'Multitenancy',
    icon: 'lucide:building-2',
    tagline: 'Isolation by default. Cross-tenant by opt-in.',
    bullets: [
      'Finbuckle.MultiTenant 10 (claim, header, query)',
      'EF Core global query filter for tenant scoping',
      'IGlobalEntity opt-out for system-wide rows',
      'Tenant-aware caching + jobs + outbox',
    ],
    snippet: `public class Invoice : BaseEntity, IHasTenant\n{ /* tenant-scoped automatically */ }`,
    href: '/docs/modules/multitenancy/',
  },
  {
    name: 'Auditing',
    icon: 'lucide:scroll-text',
    tagline: 'A forensic record of every change.',
    bullets: [
      'EF SaveChanges interceptor captures all writes',
      'Per-entity before/after snapshot',
      'User, tenant, correlation ID, request path',
      'Queryable via /audits with filters + redaction',
    ],
    snippet: `services.AddDbContext<AppDb>(opts =>\n  opts.AddInterceptors(new AuditingInterceptor()));`,
    href: '/docs/modules/auditing/',
  },
];

// The other 7 modules that ship in v1 alongside the three pillars above.
const auxModules = [
  { name: 'Files',         icon: 'lucide:file',           summary: 'Tenant-scoped object storage on MinIO / S3' },
  { name: 'Chat',          icon: 'lucide:message-square', summary: 'Realtime channels, DMs, @mentions, threads' },
  { name: 'Notifications', icon: 'lucide:bell',           summary: 'User inbox with real-time SignalR push'      },
  { name: 'Webhooks',      icon: 'lucide:webhook',        summary: 'Tenant subscriptions, HMAC-signed payloads'  },
  { name: 'Billing',       icon: 'lucide:credit-card',    summary: 'Subscription plans and usage metering'       },
  { name: 'Catalog',       icon: 'lucide:shopping-bag',   summary: 'Products, categories, images'                },
  { name: 'Tickets',       icon: 'lucide:ticket',         summary: 'Support tickets and conversations'           },
];
---

<section
  class="relative isolate overflow-hidden border-t border-border bg-subtle/30"
  id="modules"
>
  {/* Section-dot backdrop with radial mask */}
  <div
    aria-hidden="true"
    class="section-dots absolute inset-0 -z-10 opacity-60"
    style="mask-image: radial-gradient(70% 60% at 50% 30%, black, transparent); -webkit-mask-image: radial-gradient(70% 60% at 50% 30%, black, transparent);"
  ></div>

  <div class="mx-auto w-full max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <SectionEyebrow n="03" right="10 modules ship in v1">Ten production modules ship in v1</SectionEyebrow>

    <div class="max-w-2xl">
      <h2 class="text-balance font-display font-semibold tracking-[-0.035em] text-[36px] leading-[1.04] sm:text-[48px] md:text-[56px]">
        <span class="font-light text-muted-foreground">Three pillars,</span>
        <span class="mt-1 block">
          <span class="relative inline-block text-foreground">
            <span class="relative z-[1] font-bold">seven more in the box.</span>
            <span
              aria-hidden="true"
              class="absolute -bottom-1 left-0 right-0 h-2 rounded-full"
              style="background: color-mix(in oklab, var(--primary) 50%, transparent);"
            ></span>
          </span>
        </span>
      </h2>
      <p class="mt-6 max-w-xl text-[15.5px] leading-relaxed text-muted-foreground sm:text-[16.5px]">
        Identity, Multitenancy and Auditing are the
        <span class="font-semibold text-foreground">architectural pillars</span> —
        the questions every B2B SaaS has to answer.
        Seven more modules (Files, Chat, Notifications, Webhooks, Billing, Catalog, Tickets) ship alongside them so you're
        <span class="font-semibold text-foreground">not building basics on day one</span>.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-3 md:gap-6">
      {modules.map((m) => (
        <article
          data-magnetic-card
          class="module-card group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card p-6 transition-all hover:border-border-strong hover:shadow-lg sm:p-7"
        >
          {/* Corner glow on hover */}
          <div
            aria-hidden="true"
            class="pointer-events-none absolute -right-12 -top-12 h-36 w-36 rounded-full opacity-0 transition-opacity duration-500 group-hover:opacity-100"
            style="background: radial-gradient(circle, color-mix(in oklab, var(--primary) 18%, transparent), transparent 70%);"
          ></div>

          {/* Top row: icon chip + module label */}
          <div class="relative flex items-center justify-between gap-2">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
              <Icon name={m.icon} class="h-5 w-5" />
            </span>
            <span class="font-mono text-[10px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
              Module
            </span>
          </div>

          {/* Module name */}
          <h3 class="relative mt-5 font-display text-[22px] font-semibold tracking-[-0.02em] text-foreground">
            {m.name}
          </h3>

          {/* Tagline */}
          <p class="relative mt-2 text-[14px] font-medium leading-relaxed text-foreground">
            {m.tagline}
          </p>

          {/* Bullets with star markers */}
          <ul class="relative mt-4 space-y-2 text-[13px] text-muted-foreground">
            {m.bullets.map((b) => (
              <li class="flex items-start gap-2.5">
                <svg
                  class="mt-0.5 h-3 w-3 shrink-0 text-primary"
                  viewBox="0 0 9 10"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d="M4.37316 0.851288C4.47459 0.59117 4.85275 0.624255 4.90746 0.898033L5.48015 3.76369C5.49882 3.85714 5.56384 3.93463 5.65263 3.96925L8.37531 5.03085C8.63543 5.13228 8.60234 5.51044 8.32856 5.56515L5.4629 6.13784C5.36945 6.15651 5.29197 6.22153 5.25735 6.31032L4.19574 9.033C4.09432 9.29312 3.71616 9.26003 3.66145 8.98625L3.08876 6.12059C3.07008 6.02714 3.00506 5.94966 2.91627 5.91504L0.193598 4.85343C-0.0665204 4.75201 -0.0334351 4.37385 0.240343 4.31914L3.106 3.74645C3.19945 3.72777 3.27694 3.66275 3.31156 3.57396L4.37316 0.851288Z" />
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>

          {/* Dark terminal-style code panel */}
          <div class="relative mt-5 overflow-hidden rounded-lg border border-white/5 bg-[#0d1117]">
            <div class="flex items-center gap-1.5 border-b border-white/5 bg-[#161b22] px-3 py-1.5">
              <span class="h-1.5 w-1.5 rounded-full bg-[#ff5f56]" aria-hidden></span>
              <span class="h-1.5 w-1.5 rounded-full bg-[#ffbd2e]" aria-hidden></span>
              <span class="h-1.5 w-1.5 rounded-full bg-[#27c93f]" aria-hidden></span>
              <span class="ml-2 font-mono text-[9.5px] uppercase tracking-[0.18em] text-slate-500">
                {m.name.toLowerCase()}.cs
              </span>
            </div>
            <pre class="overflow-x-auto px-3.5 py-3 font-mono text-[11.5px] leading-[1.7] text-slate-300"><code>{m.snippet}</code></pre>
          </div>

          {/* Explore link */}
          <a
            href={m.href}
            class="relative mt-6 inline-flex items-center gap-1.5 text-[13.5px] font-medium text-primary transition-all group-hover:gap-2"
          >
            Explore {m.name}
            <span aria-hidden="true">→</span>
          </a>

          {/* Magnetic shimmer overlay (defined in globals.css) */}
          <div class="magnetic-shimmer" aria-hidden="true"></div>
        </article>
      ))}
    </div>

    {/* Aux modules strip — the other 7 that ship in v1 */}
    <div class="mt-14">
      <div class="mb-6 flex items-center gap-3">
        <span class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.22em] tabular-nums text-muted-foreground">
          And seven more in the box
        </span>
        <span aria-hidden class="h-px flex-1 bg-border"></span>
      </div>

      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4 lg:gap-4">
        {auxModules.map((m) => (
          <li class="aux-module group relative overflow-hidden rounded-xl border border-border bg-card/60 p-4 transition-all hover:-translate-y-0.5 hover:border-border-strong">
            <div class="flex items-center gap-2.5">
              <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-border bg-background text-primary transition-colors group-hover:border-primary/40 group-hover:bg-primary/5">
                <Icon name={m.icon} class="h-4 w-4" />
              </span>
              <p class="font-display text-[14.5px] font-semibold tracking-[-0.01em] text-foreground">
                {m.name}
              </p>
            </div>
            <p class="mt-2 text-[12px] leading-relaxed text-muted-foreground">
              {m.summary}
            </p>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
