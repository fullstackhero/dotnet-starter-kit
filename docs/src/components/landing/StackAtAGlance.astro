---
/**
 * StackAtAGlance — section 01, the marquee opener after the Hero.
 * A bento grid stating exactly what you're running, the moment you clone.
 * Two wide "marquee" cells (.NET 10, Multitenancy) anchor a diagonal rhythm;
 * the rest are compact pillars. Staggered scroll-reveal, on-brand green system.
 */
import SectionEyebrow from './SectionEyebrow.astro';
import { Icon } from 'astro-icon/components';

type Cell = {
  icon: string;
  tag: string;
  title: string;
  desc: string;
  span?: string;
  marquee?: boolean;
  note?: string;
};

const cells: Cell[] = [
  {
    icon: 'lucide:server',
    tag: 'Backend',
    title: '.NET 10',
    desc: 'Minimal APIs, Mediator, and EF Core 10 on the latest LTS — C# 14, source-generated, fast.',
    span: 'lg:col-span-2',
    marquee: true,
  },
  {
    icon: 'lucide:atom',
    tag: 'Frontend',
    title: 'React',
    desc: 'A Vite admin console and dashboard, fully wired to the API.',
    note: 'More UI frameworks coming soon',
  },
  {
    icon: 'lucide:database',
    tag: 'Database · default',
    title: 'PostgreSQL',
    desc: 'Npgsql + EF Core out of the box. SQL Server provider included.',
  },
  {
    icon: 'lucide:orbit',
    tag: 'Orchestration · ready',
    title: '.NET Aspire',
    desc: 'One command brings up Postgres, Redis, storage, and the API.',
  },
  {
    icon: 'lucide:container',
    tag: 'Deploy',
    title: 'Docker Compose',
    desc: 'A production compose file in the box — ship it anywhere.',
  },
  {
    icon: 'lucide:cloud',
    tag: 'Storage · S3',
    title: 'S3-compatible',
    desc: 'Local disk in dev; any S3 provider (or MinIO) in production.',
  },
  {
    icon: 'lucide:building-2',
    tag: 'Tenancy · built-in',
    title: 'Multitenancy',
    desc: 'Finbuckle-powered tenant isolation across every module and DbContext — claim, header, or query-string resolution.',
    span: 'lg:col-span-2',
    marquee: true,
  },
];
---

<section class="relative isolate overflow-hidden border-t border-border" id="stack">
  {/* Airy radial glow — keeps the bento the focus; distinct from CodeFirst's dot-grid below */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background: radial-gradient(46rem 30rem at 50% -2%, color-mix(in oklab, var(--primary) 8%, transparent), transparent 65%);"
  ></div>

  <div class="mx-auto w-full max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <SectionEyebrow right="Opinionated defaults · swap any of them">The stack</SectionEyebrow>

    <div class="max-w-2xl">
      <h2 class="text-balance font-display font-semibold tracking-[-0.035em] text-[34px] leading-[1.04] sm:text-[44px] md:text-[52px]">
        <span class="font-light text-muted-foreground">An opinionated, production-ready stack,</span>
        <span class="mt-1 block">
          <span class="relative inline-block text-foreground">
            <span class="relative z-[1] font-bold">from day one.</span>
            <span
              aria-hidden="true"
              class="absolute -bottom-1 left-0 right-0 h-2 rounded-full"
              style="background: color-mix(in oklab, var(--primary) 50%, transparent);"
            ></span>
          </span>
        </span>
      </h2>
      <p class="mt-5 text-[15.5px] leading-relaxed text-muted-foreground sm:text-[16.5px]">
        The unglamorous infrastructure every product needs — already chosen, already connected. Sensible,
        production-grade defaults, and nothing you can't swap.
      </p>
    </div>

    <div class="fsh-stack mt-12 grid grid-cols-1 gap-3 sm:mt-14 sm:grid-cols-2 sm:gap-4 lg:grid-cols-3" data-stack-grid>
      {cells.map((c, i) => (
        <article
          class:list={[
            'stack-cell group relative flex flex-col overflow-hidden rounded-2xl border border-border bg-card p-5 sm:p-6',
            c.span,
            c.marquee && 'sm:col-span-2',
          ]}
          style={`--d:${i * 65}ms`}
        >
          {c.marquee && (
            <Icon
              name={c.icon}
              class="pointer-events-none absolute -bottom-5 -right-4 h-32 w-32 text-primary/[0.06] transition-transform duration-500 group-hover:scale-105"
              aria-hidden="true"
            />
          )}

          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-inset ring-primary/15">
            <Icon name={c.icon} class="h-5 w-5" aria-hidden="true" />
          </span>

          <span class="mt-4 font-mono text-[10px] font-semibold uppercase tracking-[0.16em] text-muted-foreground">
            {c.tag}
          </span>

          <h3
            class:list={[
              'mt-1 font-display font-bold tracking-tight text-foreground',
              c.marquee ? 'text-[26px] sm:text-[30px]' : 'text-[19px]',
            ]}
          >
            {c.title}
          </h3>

          <p
            class:list={[
              'mt-2 leading-relaxed text-muted-foreground',
              c.marquee ? 'max-w-md text-[14px]' : 'text-[13px]',
            ]}
          >
            {c.desc}
          </p>

          {c.note && (
            <span class="mt-3 inline-flex w-fit items-center gap-1.5 rounded-full border border-primary/25 bg-primary/[0.06] px-2.5 py-1 font-mono text-[10px] font-semibold uppercase tracking-[0.12em] text-primary">
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-primary" aria-hidden="true"></span>
              {c.note}
            </span>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Card polish — soft lift via shadow + border only (no transform, so it
     never fights the reveal animation's translate). */
  .stack-cell {
    transition: border-color 240ms ease, box-shadow 240ms ease, background-color 240ms ease;
  }
  .stack-cell:hover {
    border-color: var(--border-strong);
    box-shadow: 0 14px 40px -22px color-mix(in oklab, var(--primary) 38%, transparent);
  }

  /* Staggered scroll-reveal — armed only when JS runs (progressive
     enhancement: no-JS / reduced-motion users see everything immediately). */
  .fsh-stack.is-armed .stack-cell {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 520ms ease,
      transform 520ms cubic-bezier(0.22, 0.61, 0.36, 1),
      border-color 240ms ease,
      box-shadow 240ms ease;
    transition-delay: var(--d, 0ms);
  }
  .fsh-stack.is-armed.is-in .stack-cell {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .stack-cell { transition: none; }
  }
</style>

<script>
  // Arm the staggered reveal and trigger it when the grid scrolls into view.
  // Idempotent + view-transition aware.
  (() => {
    const init = () => {
      const grids = document.querySelectorAll<HTMLElement>('[data-stack-grid]');
      grids.forEach((grid) => {
        if (grid.dataset.fshBound === '1') return;
        grid.dataset.fshBound = '1';
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        grid.classList.add('is-armed');
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                grid.classList.add('is-in');
                io.disconnect();
                break;
              }
            }
          },
          { threshold: 0.15 },
        );
        io.observe(grid);
      });
    };

    init();
    document.addEventListener('astro:page-load', init);
  })();
</script>
