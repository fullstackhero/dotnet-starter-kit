---
/**
 * Hero — conversion-first landing surface.
 *
 * Modeled on the editorial pattern from
 * codewithmukesh/blog/src/pages/resources/dotnet-claude-kit/_Hero.astro
 *   ─ magazine eyebrow rule
 *   ─ live release chip (pulse dot)
 *   ─ display headline with light/bold split + gradient underline strip
 *   ─ subtitle with inline bold stats
 *   ─ primary + secondary CTAs
 *   ─ trust strip
 *   ─ animated terminal: typewriter command + staggered reveal of output
 *   ─ stat-card grid with EQ-tick hover dance
 *
 * All animations are pointer + reduced-motion aware. The terminal script
 * lives in src/scripts/hero-terminal.ts and is wired here via <script>.
 */
import { Icon } from 'astro-icon/components';
import Button from '../brand/Button.astro';
import siteConfig from '../../data/site';
import { getStars } from '../../helpers/github-stars';

const stars = await getStars();

const heroStats = [
  { value: '10',  unit: '',  label: 'Modules',          note: 'Identity · Multitenancy · Auditing · +7 more', icon: 'lucide:box'         },
  { value: '12',  unit: '',  label: 'Building blocks',  note: 'EF · Redis · Hangfire · OTel · Eventing · …',  icon: 'lucide:layers'      },
  { value: '900', unit: '+', label: 'Tests',            note: 'Unit + integration · green',                   icon: 'lucide:check-check' },
  { value: '1',   unit: '',  label: 'Command',          note: '`dotnet run` boots the whole stack via Aspire 13',icon: 'lucide:rocket'    },
];
---

<header
  data-track-section="hero"
  class="relative isolate overflow-hidden pt-12 sm:pt-16 md:pt-20 pb-12 sm:pb-16"
  id="hero-section"
>
  {/* Dotted backdrop with radial mask — focal point under headline */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background-image: radial-gradient(circle at 1px 1px, color-mix(in oklab, var(--foreground) 14%, transparent) 1px, transparent 0); background-size: 24px 24px; mask-image: radial-gradient(70% 60% at 50% 25%, black, transparent); -webkit-mask-image: radial-gradient(70% 60% at 50% 25%, black, transparent);"
  ></div>

  {/* Brand glow blob behind everything */}
  <div class="brand-shadow" aria-hidden="true"></div>

  <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
    {/* Magazine eyebrow rule */}
    <div class="mb-10 sm:mb-14 flex items-center gap-3 sm:gap-4">
      <span class="shrink-0 font-mono text-[11px] font-semibold uppercase tracking-[0.16em] tabular-nums text-primary">
        Open source · .NET 10 starter kit
      </span>
      <span class="h-px flex-1 bg-border" aria-hidden></span>
      <span class="hidden shrink-0 font-mono text-[11px] font-medium uppercase tracking-[0.16em] tabular-nums text-muted-foreground sm:inline">
        v10 · MIT · production-ready
      </span>
    </div>

    {/* Centered hero copy */}
    <div class="relative mx-auto flex max-w-3xl flex-col items-center text-center">
      {/* Brand mark — the recognizable FSH logo, crowning the hero */}
      <div class="fsh-hero-logo mb-7 sm:mb-8">
        <img
          src="/logo-fullstackhero.png"
          alt="fullstackhero"
          width="80"
          height="80"
          class="h-16 w-16 rounded-2xl sm:h-20 sm:w-20"
          loading="eager"
          decoding="async"
        />
      </div>

      {/* Social-proof chip — lead with star count */}
      <a
        href={siteConfig.repo}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`fullstackhero on GitHub — ${stars.count.toLocaleString()} stars`}
        class="group inline-flex items-center gap-2 rounded-full border border-border/60 bg-card/70 py-1 pl-1 pr-3 text-[12.5px] text-muted-foreground backdrop-blur-md transition-colors hover:border-border-strong hover:text-foreground dark:border-border/30"
      >
        <span class="inline-flex items-center gap-1.5 rounded-full bg-foreground/[0.06] px-2.5 py-0.5">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor" class="text-saffron" aria-hidden="true">
            <path d="M12 2l2.78 6.83L22 9.91l-5.46 4.73L18.18 22 12 18.27 5.82 22l1.64-7.36L2 9.91l7.22-1.08L12 2z"/>
          </svg>
          <span class="font-semibold tabular-nums text-foreground">{stars.formatted}</span>
        </span>
        <span>stars on GitHub</span>
        <span aria-hidden="true" class="opacity-40">·</span>
        <span class="relative inline-flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full rounded-full bg-success opacity-60 pulse-dot"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-success"></span>
        </span>
        <span class="font-medium text-foreground">v10 in progress</span>
        <span aria-hidden class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>

      {/* Display headline — light/bold split with gradient underline */}
      <h1 class="mt-7 text-balance font-display font-semibold tracking-[-0.035em] text-[42px] leading-[1.02] sm:text-[60px] md:text-[72px]">
        <span class="font-light text-muted-foreground">The .NET 10 starter kit</span>
        <span class="mt-1 block">
          <span class="relative inline-block text-foreground">
            <span class="relative z-[1] font-bold">built to ship, not to demo.</span>
            <span
              aria-hidden="true"
              class="absolute -bottom-1 left-0 right-0 h-2 rounded-full"
              style="background: color-mix(in oklab, var(--primary) 50%, transparent);"
            ></span>
          </span>
        </span>
      </h1>

      {/* Subtitle — citable definition paragraph for AI + keyword density */}
      <p class="mt-6 max-w-2xl text-[16px] leading-relaxed text-muted-foreground sm:text-[17.5px]">
        <span class="font-semibold text-foreground">fullstackhero</span> is the
        <span class="font-semibold text-foreground">free, MIT-licensed .NET 10 starter kit</span>
        for teams shipping production SaaS — paired with a
        <span class="font-semibold text-foreground">React + Vite</span> admin and dashboard out of the box.
        <span class="font-semibold text-foreground">Ten modules</span> — identity, multitenancy, auditing, files, chat, notifications, webhooks, billing, catalog, tickets — wired through a
        <span class="font-semibold text-foreground">modular monolith</span> with
        <span class="font-semibold text-foreground">Vertical Slice Architecture</span>.
        <span class="font-semibold text-foreground">A real codebase, not a tutorial.</span>
        No vendor framework. No lock-in.
      </p>

      {/* CTAs — primary ink, secondary with live star count badge */}
      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <Button href="/docs/getting-started/quick-start/" variant="primary" size="lg" class="group">
          Get started
          <span aria-hidden class="transition-transform group-hover:translate-x-0.5">→</span>
        </Button>
        <a
          href={siteConfig.repo}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Star fullstackhero on GitHub — ${stars.count.toLocaleString()} stars`}
          class="group inline-flex h-11 items-center overflow-hidden rounded-md border border-border bg-card text-[14.5px] font-medium text-foreground transition-all hover:border-border-strong"
        >
          <span class="inline-flex h-full items-center gap-2 pl-4 pr-3.5">
            <Icon name="lucide:github" class="h-4 w-4" />
            Star on GitHub
          </span>
          <span class="inline-flex h-full items-center gap-1.5 border-l border-border bg-foreground/[0.04] px-3.5 tabular-nums transition-colors group-hover:bg-foreground/[0.07]">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" class="text-saffron" aria-hidden="true">
              <path d="M12 2l2.78 6.83L22 9.91l-5.46 4.73L18.18 22 12 18.27 5.82 22l1.64-7.36L2 9.91l7.22-1.08L12 2z"/>
            </svg>
            <span class="text-foreground">{stars.formatted}</span>
          </span>
        </a>
      </div>

      {/* Trust strip */}
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-[12.5px] tabular-nums text-muted-foreground">
        <li class="inline-flex items-center gap-1.5">
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full" style="background: var(--success);" aria-hidden></span>
          <span class="font-medium text-foreground">v10</span>
        </li>
        <li aria-hidden class="text-muted-foreground/40">·</li>
        <li>MIT licensed</li>
        <li aria-hidden class="text-muted-foreground/40">·</li>
        <li>.NET 10 / C# 14</li>
        <li aria-hidden class="text-muted-foreground/40">·</li>
        <li>PostgreSQL · Redis · React</li>
      </ul>
    </div>

    {/* Animated terminal preview — typewriter command + staggered reveal */}
    <div class="relative mx-auto mt-14 max-w-3xl sm:mt-20" id="hero-terminal">
      <div class="overflow-hidden rounded-2xl border border-border bg-[#0d1117] shadow-lg shadow-black/20 dark:shadow-black/40">
        {/* Title bar */}
        <div class="flex items-center justify-between gap-3 border-b border-white/5 bg-[#161b22] px-4 py-2.5">
          <div class="flex min-w-0 items-center gap-3">
            <span class="flex shrink-0 gap-1.5" aria-hidden="true">
              <span class="h-2.5 w-2.5 rounded-full bg-[#ff5f56]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#ffbd2e]"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#27c93f]"></span>
            </span>
            <span class="truncate font-mono text-[11px] uppercase tracking-[0.18em] text-slate-500">
              fsh starter session
            </span>
          </div>
          <span class="hidden truncate font-mono text-[11px] text-slate-500 sm:inline">
            ~/fullstackhero
          </span>
        </div>

        {/* Body */}
        <div class="p-5 font-mono text-[13.5px] leading-relaxed sm:text-sm" id="hero-terminal-body">
          {/* Line 0 — typewriter command */}
          <div class="terminal-line flex items-baseline" data-delay="0">
            <span class="text-emerald-400">$</span><span class="text-slate-300" id="hero-typewriter"></span><span class="terminal-cursor inline-block h-4 w-[2px] translate-y-[2px] bg-emerald-400"></span>
          </div>

          {/* Aspire orchestration boot lines — mirror the actual AppHost.cs */}
          <div class="terminal-line mt-3 hidden" data-delay="2200">
            <span class="text-amber-400">↪</span>
            <span class="text-slate-300"> Starting Aspire 13 orchestration…</span>
          </div>
          <div class="terminal-line mt-1 hidden" data-delay="2900">
            <span class="text-emerald-400">✓</span>
            <span class="text-slate-300"> postgres</span>
            <span class="text-slate-500">       tcp/5432</span>
          </div>
          <div class="terminal-line mt-1 hidden" data-delay="3200">
            <span class="text-emerald-400">✓</span>
            <span class="text-slate-300"> redis</span>
            <span class="text-slate-500">          tcp/6379</span>
          </div>
          <div class="terminal-line mt-1 hidden" data-delay="3500">
            <span class="text-emerald-400">✓</span>
            <span class="text-slate-300"> minio (S3)</span>
            <span class="text-slate-500">     :9000 · :9001</span>
          </div>
          <div class="terminal-line mt-1 hidden" data-delay="3800">
            <span class="text-emerald-400">✓</span>
            <span class="text-slate-300"> db-migrator</span>
            <span class="text-slate-500">    schema applied</span>
          </div>
          <div class="terminal-line mt-1 hidden" data-delay="4100">
            <span class="text-emerald-400">✓</span>
            <span class="text-slate-300"> fsh-api</span>
            <span class="text-slate-500">        http://localhost:5000</span>
          </div>
          <div class="terminal-line mt-1 hidden" data-delay="4400">
            <span class="text-emerald-400">✓</span>
            <span class="text-slate-300"> fsh-admin</span>
            <span class="text-slate-500">      http://localhost:5173</span>
          </div>
          <div class="terminal-line mt-1 hidden" data-delay="4700">
            <span class="text-emerald-400">✓</span>
            <span class="text-slate-300"> fsh-dashboard</span>
            <span class="text-slate-500">  http://localhost:5174</span>
          </div>

          {/* Verdict — no fictional timing */}
          <div class="terminal-line mt-3 hidden" data-delay="5300">
            <span style="color: var(--primary-soft);" class="font-semibold">All services up</span>
            <span class="text-slate-600"> ·</span>
            <span class="text-slate-300"> multitenancy enforced</span>
            <span class="text-slate-600"> ·</span>
            <span class="text-slate-300"> traces flowing to OTLP</span>
          </div>
        </div>
      </div>

      {/* Below-terminal caption */}
      <p class="mt-4 text-center font-mono text-[11.5px] uppercase tracking-[0.18em] tabular-nums text-muted-foreground">
        Live preview ·
        <span class="text-foreground font-semibold">7 services</span>
        orchestrated by
        <span class="text-foreground font-semibold">Aspire 13</span>
      </p>
    </div>

    {/* Stat grid — 4 metric cards with EQ-tick hover */}
    <div class="mt-14 sm:mt-20">
      <div class="mb-6 flex items-center gap-3">
        <span class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.22em] tabular-nums text-muted-foreground">
          What ships in v10
        </span>
        <span aria-hidden class="h-px flex-1 bg-border"></span>
      </div>

      <ul class="hero-stats-grid grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-4">
        {heroStats.map((s) => (
          <li class="hero-stat-card group relative overflow-hidden rounded-2xl border border-border bg-card p-5 transition-all hover:-translate-y-0.5 hover:border-border-strong sm:p-6">
            {/* Corner glow on hover */}
            <div
              aria-hidden="true"
              class="pointer-events-none absolute -right-12 -top-12 h-32 w-32 rounded-full opacity-0 transition-opacity duration-500 group-hover:opacity-100"
              style="background: radial-gradient(circle, color-mix(in oklab, var(--primary) 18%, transparent), transparent 70%);"
            ></div>

            {/* Top row */}
            <div class="relative flex items-center justify-between gap-2">
              <span class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                {s.label}
              </span>
              <span
                aria-hidden="true"
                class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-border bg-background text-primary transition-all duration-300 group-hover:border-primary/40 group-hover:bg-primary/5"
              >
                <Icon name={s.icon} class="h-4 w-4" />
              </span>
            </div>

            {/* Big number */}
            <p class="relative mt-5 font-display font-bold leading-[0.88] tracking-[-0.045em] tabular-nums text-foreground text-[52px] sm:mt-6 sm:text-[64px] md:text-[72px]">
              <span class="hero-stat-value inline-block">{s.value}</span>
              {s.unit && (
                <span class="hero-stat-unit ml-0.5 mt-[0.18em] inline-block align-top font-bold tracking-tight text-primary text-[0.4em]">
                  {s.unit}
                </span>
              )}
            </p>

            {/* Bottom: EQ ticks + description */}
            <div class="relative mt-5 flex items-end gap-3 border-t border-border pt-4">
              <div class="hero-stat-ticks flex shrink-0 items-end gap-[3px]" aria-hidden="true">
                <span class="h-1.5 w-[3px] rounded-full bg-primary/25"></span>
                <span class="h-3 w-[3px] rounded-full bg-primary/55"></span>
                <span class="h-[18px] w-[3px] rounded-full bg-primary"></span>
                <span class="h-2.5 w-[3px] rounded-full bg-primary/45"></span>
                <span class="h-1.5 w-[3px] rounded-full bg-primary/25"></span>
              </div>
              <p class="text-[12px] leading-tight text-muted-foreground">{s.note}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <style is:global>
    /* Hero brand mark — recognizable FSH logo with a soft green halo + gentle float */
    .fsh-hero-logo {
      position: relative;
      display: inline-flex;
    }
    .fsh-hero-logo::before {
      content: "";
      position: absolute;
      inset: -38%;
      border-radius: 9999px;
      background: radial-gradient(circle, color-mix(in oklab, var(--primary) 20%, transparent), transparent 70%);
      filter: blur(16px);
      z-index: -1;
    }
    .fsh-hero-logo img {
      filter: drop-shadow(0 12px 30px color-mix(in oklab, var(--primary) 30%, transparent));
      animation: fsh-logo-float 5.5s ease-in-out infinite;
    }
    @keyframes fsh-logo-float {
      0%, 100% { transform: translateY(0); }
      50%      { transform: translateY(-5px); }
    }

    /* Terminal cursor blink */
    .terminal-cursor {
      animation: hero-cursor-blink 1s step-end infinite;
    }
    @keyframes hero-cursor-blink {
      50% { opacity: 0; }
    }

    /* Modern metric-card hover: number lifts, unit tints, EQ ticks dance */
    .hero-stat-card .hero-stat-value,
    .hero-stat-card .hero-stat-unit {
      transition:
        transform 480ms cubic-bezier(0.2, 0, 0, 1),
        color 320ms cubic-bezier(0.2, 0, 0, 1);
      transform-origin: left center;
    }
    .hero-stat-card:hover .hero-stat-value {
      transform: translateY(-2px);
    }
    .hero-stat-card:hover .hero-stat-unit {
      color: color-mix(in oklab, var(--primary) 80%, var(--foreground));
      transform: translateY(-2px) translateX(2px);
    }

    .hero-stat-ticks > span {
      transition: transform 320ms cubic-bezier(0.2, 0, 0, 1);
      transform-origin: bottom center;
    }
    @keyframes hero-tick-dance {
      0%, 100% { transform: scaleY(0.7); }
      50%      { transform: scaleY(1.35); }
    }
    .hero-stat-card:hover .hero-stat-ticks > span:nth-child(1) { animation: hero-tick-dance 1.05s ease-in-out infinite; }
    .hero-stat-card:hover .hero-stat-ticks > span:nth-child(2) { animation: hero-tick-dance 1.05s ease-in-out 0.10s infinite; }
    .hero-stat-card:hover .hero-stat-ticks > span:nth-child(3) { animation: hero-tick-dance 1.05s ease-in-out 0.20s infinite; }
    .hero-stat-card:hover .hero-stat-ticks > span:nth-child(4) { animation: hero-tick-dance 1.05s ease-in-out 0.30s infinite; }
    .hero-stat-card:hover .hero-stat-ticks > span:nth-child(5) { animation: hero-tick-dance 1.05s ease-in-out 0.40s infinite; }

    @media (prefers-reduced-motion: reduce) {
      .terminal-cursor { animation: none !important; }
      .fsh-hero-logo img { animation: none !important; }
      .hero-stat-card .hero-stat-value,
      .hero-stat-card .hero-stat-unit,
      .hero-stat-ticks > span { transition: none !important; animation: none !important; }
      .hero-stat-card:hover .hero-stat-value,
      .hero-stat-card:hover .hero-stat-unit { transform: none !important; }
    }
  </style>

  <script>
    function initHeroTerminal() {
      const tw = document.getElementById('hero-typewriter');
      if (!tw || tw.dataset.heroInit === 'true') return;
      tw.dataset.heroInit = 'true';

      const fullText = ' dotnet run --project src/Host/FSH.Starter.AppHost';
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Reveal helper for staggered output lines
      const lines = document.querySelectorAll<HTMLElement>('#hero-terminal-body .terminal-line[data-delay]');
      const revealLine = (el: HTMLElement) => {
        el.classList.remove('hidden');
        el.style.opacity = '0';
        el.style.transform = 'translateY(4px)';
        requestAnimationFrame(() => {
          el.style.transition = 'opacity 320ms cubic-bezier(0.2, 0, 0, 1), transform 320ms cubic-bezier(0.2, 0, 0, 1)';
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        });
      };

      // Schedule all reveals up-front
      lines.forEach((el) => {
        const delay = Number(el.dataset.delay ?? '0');
        if (reduced) {
          el.classList.remove('hidden');
        } else {
          setTimeout(() => revealLine(el), delay);
        }
      });

      // Typewriter for the command
      if (reduced) {
        tw.textContent = fullText;
        return;
      }
      let i = 0;
      const type = () => {
        if (i <= fullText.length) {
          tw.textContent = fullText.slice(0, i);
          i++;
          setTimeout(type, 38);
        }
      };
      type();
    }

    initHeroTerminal();
    document.addEventListener('astro:after-swap', initHeroTerminal);
  </script>
</header>
