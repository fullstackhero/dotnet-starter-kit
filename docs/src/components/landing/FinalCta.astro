---
import CopyCommand from './CopyCommand.astro';
import SectionEyebrow from './SectionEyebrow.astro';
import Button from '../brand/Button.astro';
import { Icon } from 'astro-icon/components';
import siteConfig from '../../data/site';
---

<section
  class="relative isolate overflow-hidden border-t border-border bg-gradient-to-b from-transparent to-subtle/60"
  id="final-cta"
>
  {/* Dotted backdrop fading from top */}
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
    style="background-image: radial-gradient(circle at 1px 1px, color-mix(in oklab, var(--foreground) 14%, transparent) 1px, transparent 0); background-size: 24px 24px; mask-image: radial-gradient(60% 50% at 50% 40%, black, transparent); -webkit-mask-image: radial-gradient(60% 50% at 50% 40%, black, transparent);"
  ></div>

  <div class="mx-auto w-full max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <SectionEyebrow n="05" right="v1 · MIT · open source">Ready to build</SectionEyebrow>

    {/* Centered hero copy */}
    <div class="relative mx-auto flex max-w-2xl flex-col items-center text-center">
      {/* Light/bold split headline with green underline strip */}
      <h2 class="text-balance font-display font-semibold tracking-[-0.035em] text-[36px] leading-[1.04] sm:text-[48px] md:text-[60px]">
        <span class="font-light text-muted-foreground">Start</span>
        <span class="mt-1 block">
          <span class="relative inline-block text-foreground">
            <span class="relative z-[1] font-bold">where you'd finish.</span>
            <span
              aria-hidden="true"
              class="absolute -bottom-1 left-0 right-0 h-2 rounded-full"
              style="background: color-mix(in oklab, var(--primary) 50%, transparent);"
            ></span>
          </span>
        </span>
      </h2>

      <p class="mt-6 max-w-xl text-[15.5px] leading-relaxed text-muted-foreground sm:text-[16.5px]">
        Skip the
        <span class="font-semibold text-foreground">scaffolding</span>. Clone, run, and start building the part of your app
        <span class="font-semibold text-foreground">no one else can build for you</span>.
      </p>

      {/* Copy command with above caption */}
      <div class="mx-auto mt-10 flex w-full max-w-md flex-col items-center gap-3">
        <p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
          <span class="text-primary">$</span> clone the starter kit
        </p>
        <CopyCommand command="git clone https://github.com/fullstackhero/dotnet-starter-kit.git" />
        <p class="font-mono text-[11px] uppercase tracking-[0.14em] tabular-nums text-muted-foreground">
          <span class="font-semibold text-foreground">≈ 5 min</span> from clone to localhost
        </p>
      </div>

      {/* CTAs */}
      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <Button href="/docs/getting-started/install/" variant="primary" size="lg" class="group">
          Get started
          <span aria-hidden class="transition-transform group-hover:translate-x-0.5">→</span>
        </Button>
        <Button href={siteConfig.repo} target="_blank" variant="secondary" size="lg">
          <Icon name="lucide:github" class="h-4 w-4" />
          View on GitHub
          <span aria-hidden class="text-[12px] opacity-70">↗</span>
        </Button>
      </div>

      {/* Trust strip */}
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-[12.5px] tabular-nums text-muted-foreground">
        <li class="inline-flex items-center gap-1.5">
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full" style="background: var(--success);" aria-hidden></span>
          <span class="font-medium text-foreground">v1</span>
        </li>
        <li aria-hidden class="text-muted-foreground/40">·</li>
        <li>MIT licensed</li>
        <li aria-hidden class="text-muted-foreground/40">·</li>
        <li>.NET 10 / C# 14</li>
        <li aria-hidden class="text-muted-foreground/40">·</li>
        <li>Free &amp; open source</li>
      </ul>
    </div>
  </div>
</section>
