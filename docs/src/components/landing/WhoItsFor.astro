---
import { Icon } from 'astro-icon/components';
import SectionEyebrow from './SectionEyebrow.astro';

const builtFor = [
  {
    title: 'Teams shipping multitenant SaaS on .NET',
    body: 'Tenant isolation is the default behaviour, not a bolt-on. Finbuckle + global query filter + tenant-aware cache/jobs/outbox are wired through every layer.',
  },
  {
    title: 'Engineering teams that want Vertical Slice + sane defaults',
    body: 'One feature lives in one folder — endpoint, handler, validator, tests. No layered ceremony. No jumping between five projects to add a button.',
  },
  {
    title: 'Indie devs and small teams shipping production B2B apps',
    body: 'Authentication, observability, background jobs, distributed cache, and two React frontends are already wired up. Day one is feature work.',
  },
  {
    title: 'Founders who want to own their code, not rent a framework',
    body: 'MIT licence; no runtime framework you can\'t walk away from. The kit uses standard ASP.NET Core, plain Microsoft.Extensions.DependencyInjection, and Microsoft + best-in-class OSS — everything your team already knows.',
  },
];

const notFor = [
  {
    title: 'Tiny CRUD apps with one entity and one user',
    body: "The kit is over-engineered for hello-world. If you don't need multitenancy or modules, a standard `dotnet new webapi` is a better starting point — there's less to delete.",
  },
  {
    title: 'Teams with a deep Clean-Architecture investment',
    body: "fullstackhero is Vertical Slice inside each module, not Clean Architecture. If your team is fluent in CA and wants the four-project layout, the Jason Taylor or Ardalis templates fit better. You can layer CA inside FSH modules, but you'd be paddling against the grain.",
  },
  {
    title: 'Microservices-from-day-one architectures',
    body: "FSH is a modular monolith — modules are split so they can be extracted into services later, but they ship as one process. If you need distributed services on day one, eShop or Aspire-on-microservices examples are a closer fit.",
  },
  {
    title: 'Teams who need paid vendor support',
    body: "FSH is community-maintained. There is no SLA, no enterprise hotline, no commercial roadmap to influence. If you need contracts and named support, ABP Commercial or BlazorPlate are paid options designed for that.",
  },
];
---

<section class="relative isolate overflow-hidden border-t border-border bg-subtle/30" id="who-its-for">
  {/* Subtle dotted backdrop */}
  <div
    class="section-dots-subtle absolute inset-0 -z-10 opacity-70"
    aria-hidden="true"
  ></div>

  <div class="mx-auto w-full max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <SectionEyebrow n="05" right="Honest fit-check">Who fullstackhero is for</SectionEyebrow>

    <div class="max-w-2xl">
      <h2 class="text-balance font-display font-semibold tracking-[-0.035em] text-[36px] leading-[1.04] sm:text-[48px] md:text-[56px]">
        <span class="font-light text-muted-foreground">It's not</span>
        <span class="mt-1 block">
          <span class="relative inline-block text-foreground">
            <span class="relative z-[1] font-bold">for everyone.</span>
            <span
              aria-hidden="true"
              class="absolute -bottom-1 left-0 right-0 h-2 rounded-full"
              style="background: color-mix(in oklab, var(--primary) 50%, transparent);"
            ></span>
          </span>
        </span>
      </h2>
      <p class="mt-6 max-w-xl text-[15.5px] leading-relaxed text-muted-foreground sm:text-[16.5px]">
        Strong defaults mean strong opinions. Here's where fullstackhero is the right answer — and where it isn't. Better to know
        <span class="font-semibold text-foreground">before you clone</span>
        than three weeks in.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-2 lg:gap-8">
      {/* Built for — primary tint */}
      <div class="fit-column rounded-2xl border border-border bg-card p-6 sm:p-7">
        <div class="mb-6 flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary">
            <Icon name="lucide:check" class="h-5 w-5" />
          </span>
          <div>
            <p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.18em] text-primary">
              Built for
            </p>
            <h3 class="font-display text-[19px] font-semibold tracking-[-0.02em] text-foreground">
              These teams should clone today
            </h3>
          </div>
        </div>
        <ul class="space-y-5">
          {builtFor.map((item) => (
            <li class="fit-item flex items-start gap-3">
              <svg class="mt-1 h-3 w-3 shrink-0 text-primary" viewBox="0 0 9 10" fill="currentColor" aria-hidden="true">
                <path d="M4.37316 0.851288C4.47459 0.59117 4.85275 0.624255 4.90746 0.898033L5.48015 3.76369C5.49882 3.85714 5.56384 3.93463 5.65263 3.96925L8.37531 5.03085C8.63543 5.13228 8.60234 5.51044 8.32856 5.56515L5.4629 6.13784C5.36945 6.15651 5.29197 6.22153 5.25735 6.31032L4.19574 9.033C4.09432 9.29312 3.71616 9.26003 3.66145 8.98625L3.08876 6.12059C3.07008 6.02714 3.00506 5.94966 2.91627 5.91504L0.193598 4.85343C-0.0665204 4.75201 -0.0334351 4.37385 0.240343 4.31914L3.106 3.74645C3.19945 3.72777 3.27694 3.66275 3.31156 3.57396L4.37316 0.851288Z" />
              </svg>
              <div class="min-w-0">
                <p class="font-display text-[15px] font-semibold tracking-[-0.01em] text-foreground">
                  {item.title}
                </p>
                <p class="mt-1 text-[13.5px] leading-relaxed text-muted-foreground">
                  {item.body}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      {/* Not for — muted */}
      <div class="fit-column rounded-2xl border border-border bg-card/60 p-6 sm:p-7">
        <div class="mb-6 flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-muted text-muted-foreground">
            <Icon name="lucide:circle-slash" class="h-5 w-5" />
          </span>
          <div>
            <p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
              Probably not for
            </p>
            <h3 class="font-display text-[19px] font-semibold tracking-[-0.02em] text-foreground">
              Use something else if any of these match
            </h3>
          </div>
        </div>
        <ul class="space-y-5">
          {notFor.map((item) => (
            <li class="fit-item flex items-start gap-3">
              <svg class="mt-1 h-3 w-3 shrink-0 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" aria-hidden="true">
                <line x1="6" y1="12" x2="18" y2="12"></line>
              </svg>
              <div class="min-w-0">
                <p class="font-display text-[15px] font-semibold tracking-[-0.01em] text-foreground">
                  {item.title}
                </p>
                <p class="mt-1 text-[13.5px] leading-relaxed text-muted-foreground">
                  {item.body}
                </p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
