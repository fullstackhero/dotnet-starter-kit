---
import { Icon } from 'astro-icon/components';
import SectionEyebrow from './SectionEyebrow.astro';

const builtFor = [
  {
    icon: 'lucide:layers',
    title: 'Teams shipping multitenant SaaS on .NET',
    body: 'Tenant isolation is the default, not a bolt-on. Finbuckle + a global query filter + tenant-aware cache, jobs, and outbox are wired through every layer.',
  },
  {
    icon: 'lucide:folder-tree',
    title: 'Teams that want Vertical Slice + sane defaults',
    body: 'One feature lives in one folder — endpoint, handler, validator, tests. No layered ceremony, no jumping between five projects to add a button.',
  },
  {
    icon: 'lucide:rocket',
    title: 'Indie devs and small teams shipping B2B apps',
    body: 'Auth, observability, background jobs, distributed cache, and two React frontends are already wired up. Day one is feature work.',
  },
  {
    icon: 'lucide:key-round',
    title: 'Founders who want to own their code',
    body: 'MIT licence; no runtime framework you can\'t walk away from. Standard ASP.NET Core, plain DI, and best-in-class OSS — everything your team already knows.',
  },
];

const notFor = [
  {
    icon: 'lucide:minimize-2',
    title: 'Tiny CRUD apps with one entity and one user',
    body: "Over-engineered for hello-world. If you don't need multitenancy or modules, a plain `dotnet new webapi` is a better start — there's less to delete.",
  },
  {
    icon: 'lucide:layout-template',
    title: 'Teams with a deep Clean-Architecture investment',
    body: 'fullstackhero is Vertical Slice inside each module, not the layered four-project structure. If your team is committed to that layout, a dedicated Clean Architecture template will feel more natural.',
  },
  {
    icon: 'lucide:network',
    title: 'Microservices-from-day-one architectures',
    body: 'FSH is a modular monolith — modules can be extracted into services later, but they ship as one process. Need distributed services on day one? A microservices-oriented start fits better.',
  },
  {
    icon: 'lucide:headset',
    title: 'Teams who need paid vendor support',
    body: 'FSH is community-maintained — no SLA, no enterprise hotline. If you need contracts and named support, a commercially-backed framework with paid support will serve you better.',
  },
];
---

<section class="relative isolate overflow-hidden border-t border-border bg-subtle/30" id="who-its-for">
  <div class="section-dots-subtle absolute inset-0 -z-10 opacity-70" aria-hidden="true"></div>

  <div class="mx-auto w-full max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <SectionEyebrow n="05" right="Honest fit-check">Who fullstackhero is for</SectionEyebrow>

    <div class="max-w-2xl">
      <h2 class="text-balance font-display font-semibold tracking-[-0.035em] text-[36px] leading-[1.04] sm:text-[48px] md:text-[56px]">
        <span class="font-light text-muted-foreground">It's not</span>
        <span class="mt-1 block">
          <span class="relative inline-block text-foreground">
            <span class="relative z-[1] font-bold">for everyone.</span>
            <span
              aria-hidden="true"
              class="absolute -bottom-1 left-0 right-0 h-2 rounded-full"
              style="background: color-mix(in oklab, var(--primary) 50%, transparent);"
            ></span>
          </span>
        </span>
      </h2>
      <p class="mt-6 max-w-xl text-[15.5px] leading-relaxed text-muted-foreground sm:text-[16.5px]">
        Strong defaults mean strong opinions. Here's where fullstackhero is the right answer — and where it
        isn't. Better to know <span class="font-semibold text-foreground">before you clone</span> than three weeks in.
      </p>
    </div>

    <div class="fsh-fit mt-14 grid gap-5 lg:grid-cols-2 lg:gap-7">
      {/* ── Built for ──────────────────────────────────────────── */}
      <div>
        <div class="mb-5 flex items-center gap-3">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-inset ring-primary/15">
            <Icon name="lucide:check" class="h-[18px] w-[18px]" />
          </span>
          <div>
            <p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.18em] text-primary">A great fit</p>
            <h3 class="font-display text-[17px] font-semibold tracking-[-0.02em] text-foreground">Clone it today if you're…</h3>
          </div>
        </div>
        <ul class="space-y-3">
          {builtFor.map((item) => (
            <li class="fit-card group relative flex gap-4 rounded-xl border border-border bg-card p-4 hover:border-primary/40 sm:p-5">
              <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary ring-1 ring-inset ring-primary/15">
                <Icon name={item.icon} class="h-[18px] w-[18px]" />
              </span>
              <div class="min-w-0">
                <p class="font-display text-[15px] font-semibold tracking-[-0.01em] text-foreground">{item.title}</p>
                <p class="mt-1 text-[13px] leading-relaxed text-muted-foreground">{item.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      {/* ── Probably not for ───────────────────────────────────── */}
      <div>
        <div class="mb-5 flex items-center gap-3">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-muted text-muted-foreground">
            <Icon name="lucide:circle-slash" class="h-[18px] w-[18px]" />
          </span>
          <div>
            <p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">Reach for something else</p>
            <h3 class="font-display text-[17px] font-semibold tracking-[-0.02em] text-foreground">Skip it if any of these match…</h3>
          </div>
        </div>
        <ul class="space-y-3">
          {notFor.map((item) => (
            <li class="fit-card group relative flex gap-4 rounded-xl border border-border bg-card/50 p-4 hover:border-border-strong sm:p-5">
              <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-muted text-muted-foreground ring-1 ring-inset ring-border">
                <Icon name={item.icon} class="h-[18px] w-[18px]" />
              </span>
              <div class="min-w-0">
                <p class="font-display text-[15px] font-semibold tracking-[-0.01em] text-foreground">{item.title}</p>
                <p class="mt-1 text-[13px] leading-relaxed text-muted-foreground">{item.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  /* Card lift — calm, shadow + border only (matches the rest of the site). */
  .fit-card {
    transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease, background-color 220ms ease;
  }
  @media (min-width: 1024px) {
    .fit-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px -20px color-mix(in oklab, var(--foreground) 40%, transparent);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .fit-card { transition: none; }
  }
</style>
