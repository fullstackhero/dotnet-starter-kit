---
/**
 * SectionEyebrow — magazine-style section heading rule.
 *
 * Renders a full-width row with:
 *   ─ left:  mono primary-tinted label, e.g. "01 · Vertical Slice"
 *   ─ mid:   hairline rule (border) that fills available space
 *   ─ right: optional mono muted meta tag (hidden on mobile)
 *
 * Matches the eyebrow rule used on the Hero so every section opens
 * with the same magazine rhythm.
 *
 * Props:
 *   n      — section number string (renders before the label, optional)
 *   right  — small meta line on the far right (optional, hidden < sm)
 *
 * Default slot is the eyebrow label text.
 */
interface Props {
  n?: string;
  right?: string;
  class?: string;
}

const { n, right, class: classList } = Astro.props as Props;
---

<div
  class:list={[
    'mb-10 flex items-center gap-3 sm:mb-14 sm:gap-4',
    classList,
  ]}
>
  <span class="shrink-0 font-mono text-[11px] font-semibold uppercase tracking-[0.16em] tabular-nums text-primary">
    {n && <><span class="tabular-nums">{n}</span><span class="mx-1.5 opacity-50">·</span></>}<slot />
  </span>
  <span class="h-px flex-1 bg-border" aria-hidden="true"></span>
  {right && (
    <span class="hidden shrink-0 font-mono text-[11px] font-medium uppercase tracking-[0.16em] tabular-nums text-muted-foreground sm:inline">
      {right}
    </span>
  )}
</div>
