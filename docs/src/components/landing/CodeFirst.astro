---
/**
 * CodeFirst — section 01, the architecture story.
 * Two balanced "boards": (left) the modular monolith — ten isolated modules in
 * one process; (right) a vertical slice — one feature as one folder of layered
 * files on a rail. The highlighted Identity module on the left is the feature
 * exploded on the right, so the two ideas read as one architecture.
 */
import { Icon } from 'astro-icon/components';
import SectionEyebrow from './SectionEyebrow.astro';

const modules = [
  { name: 'Identity', icon: 'lucide:shield-check', active: true },
  { name: 'Multitenancy', icon: 'lucide:building-2' },
  { name: 'Auditing', icon: 'lucide:scroll-text' },
  { name: 'Catalog', icon: 'lucide:shopping-bag' },
  { name: 'Files', icon: 'lucide:file' },
  { name: 'Chat', icon: 'lucide:message-square' },
  { name: 'Billing', icon: 'lucide:credit-card' },
  { name: 'Webhooks', icon: 'lucide:webhook' },
  { name: 'Notifications', icon: 'lucide:bell' },
  { name: 'Tickets', icon: 'lucide:ticket' },
];

const slice = [
  { file: 'RegisterUserEndpoint.cs', role: 'Minimal API endpoint', icon: 'lucide:route' },
  { file: 'RegisterUserCommandHandler.cs', role: 'Mediator command handler', icon: 'lucide:cog' },
  { file: 'RegisterUserCommandValidator.cs', role: 'FluentValidation rules', icon: 'lucide:shield-check' },
  { file: 'RegisterUserTests.cs', role: 'Unit + integration tests', icon: 'lucide:flask-conical' },
];
---

<section class="relative isolate overflow-hidden border-t border-border bg-subtle/40" id="code-first">
  <div
    class="section-dots absolute inset-0 -z-10 opacity-60"
    style="mask-image: radial-gradient(80% 70% at 50% 25%, black, transparent); -webkit-mask-image: radial-gradient(80% 70% at 50% 25%, black, transparent);"
    aria-hidden="true"
  ></div>

  <div class="mx-auto w-full max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8">
    <SectionEyebrow n="01" right="One process · many bounded contexts">Modular monolith + vertical slice</SectionEyebrow>

    <div class="max-w-2xl">
      <h2 class="text-balance font-display font-semibold tracking-[-0.035em] text-[34px] leading-[1.04] sm:text-[44px] md:text-[52px]">
        <span class="font-light text-muted-foreground">A modular monolith,</span>
        <span class="mt-1 block">
          <span class="relative inline-block text-foreground">
            <span class="relative z-[1] font-bold">sliced vertically.</span>
            <span
              aria-hidden="true"
              class="absolute -bottom-1 left-0 right-0 h-2 rounded-full"
              style="background: color-mix(in oklab, var(--primary) 50%, transparent);"
            ></span>
          </span>
        </span>
      </h2>
      <p class="mt-5 text-[15.5px] leading-relaxed text-muted-foreground sm:text-[16.5px]">
        Each module is an isolated bounded context, talking to the others only through its contracts — never
        reaching into their internals. Inside a module, every feature is a vertical slice: endpoint, handler,
        validator, and tests in one folder.
      </p>
    </div>

    <div class="mt-12 grid items-stretch gap-5 sm:mt-14 lg:grid-cols-2 lg:gap-6">
      {/* ── LEFT: modular monolith ───────────────────────────── */}
      <div class="arch-card flex flex-col rounded-2xl border border-border bg-card p-6 sm:p-7">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-inset ring-primary/15">
            <Icon name="lucide:layers" class="h-5 w-5" />
          </span>
          <div>
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.16em] text-primary">Modular monolith</p>
            <h3 class="font-display text-[16px] font-semibold tracking-[-0.01em] text-foreground">Ten modules, one process</h3>
          </div>
        </div>

        <div class="mt-6 grid grid-cols-2 gap-2.5">
          {modules.map((m) => (
            <div
              class:list={[
                'arch-tile flex items-center gap-2.5 rounded-xl border px-3 py-2.5',
                m.active ? 'border-primary/45 bg-primary/[0.07]' : 'border-border bg-background/40',
              ]}
            >
              <Icon name={m.icon} class:list={['h-4 w-4 shrink-0', m.active ? 'text-primary' : 'text-muted-foreground']} />
              <span class:list={['truncate text-[13px] font-medium tracking-tight', m.active ? 'text-foreground' : 'text-foreground/75']}>
                {m.name}
              </span>
            </div>
          ))}
        </div>

        <p class="mt-auto flex items-start gap-2 border-t border-border/60 pt-5 text-[12px] leading-relaxed text-muted-foreground">
          <Icon name="lucide:git-compare-arrows" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-primary/80" />
          Cross-module calls go through <code class="mx-1 rounded bg-foreground/[0.06] px-1 font-mono text-[11px] text-foreground">*.Contracts</code> only — enforced by architecture tests.
        </p>
      </div>

      {/* ── RIGHT: vertical slice ────────────────────────────── */}
      <div class="arch-card flex flex-col rounded-2xl border border-border bg-card p-6 sm:p-7">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-primary/10 text-primary ring-1 ring-inset ring-primary/15">
            <Icon name="lucide:folder-tree" class="h-5 w-5" />
          </span>
          <div>
            <p class="font-mono text-[10px] font-semibold uppercase tracking-[0.16em] text-primary">Vertical slice</p>
            <h3 class="font-display text-[16px] font-semibold tracking-[-0.01em] text-foreground">One feature, one folder</h3>
          </div>
        </div>

        {/* breadcrumb into the highlighted module */}
        <p class="mt-6 truncate font-mono text-[11px] text-muted-foreground">
          <span class="text-foreground/70">Modules.Identity</span>
          <span class="text-border">/</span> Features <span class="text-border">/</span> v1 <span class="text-border">/</span> Users
          <span class="text-border">/</span> <span class="text-primary">RegisterUser</span>
        </p>

        <div class="relative mt-4 pl-4">
          <span class="absolute bottom-3 left-0 top-3 w-0.5 rounded-full bg-primary/30" aria-hidden="true"></span>
          <ul class="space-y-2.5">
            {slice.map((s) => (
              <li class="arch-tile flex items-center gap-3 rounded-xl border border-border bg-background/40 px-3.5 py-2.5">
                <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary ring-1 ring-inset ring-primary/15">
                  <Icon name={s.icon} class="h-4 w-4" />
                </span>
                <span class="flex min-w-0 flex-col">
                  <span class="truncate font-mono text-[12.5px] text-foreground">{s.file}</span>
                  <span class="text-[11px] text-muted-foreground">{s.role}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>

        <p class="mt-auto flex items-start gap-2 border-t border-border/60 pt-5 text-[12px] leading-relaxed text-muted-foreground">
          <Icon name="lucide:git-pull-request" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-primary/80" />
          No jumping between five projects to add a button — one folder, one PR, one merge.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .arch-tile {
    transition: border-color 200ms ease, background-color 200ms ease, transform 200ms ease;
  }
  .arch-tile:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }
  @media (prefers-reduced-motion: reduce) {
    .arch-tile { transition: none; }
  }
</style>
