---
/**
 * ThemeToggle — DSS-pattern circular toggle.
 *
 * Two-state toggle (light ↔ dark). Sun shows in light mode, moon in dark.
 * Multiple instances on a page are wired by querying `[data-theme-toggle]`.
 *
 * Persistence uses localStorage key `"theme"` (kept identical to blog so
 * cross-property visitors keep their saved preference).
 */
type Props = {
  buttonId?: string;
};

const { buttonId } = Astro.props;
---

<button
  type="button"
  id={buttonId}
  data-theme-toggle
  class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-border/60 bg-card/70 text-muted-foreground transition-colors hover:border-border-strong hover:text-foreground backdrop-blur-md dark:border-border/30"
  aria-label="Toggle theme"
  title="Toggle theme"
>
  <!-- Sun (light mode) -->
  <svg
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    class="dark:hidden"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
  </svg>
  <!-- Moon (dark mode) -->
  <svg
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    class="hidden dark:inline"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script is:inline>
  // Inline + plain JS so this runs synchronously after the button parses,
  // with no bundler ambiguity. View Transitions removed to eliminate a
  // potential timing source of flaky toggles.
  (function () {
    var STORAGE_KEY = 'theme';

    function applyTheme(theme) {
      var root = document.documentElement;
      if (theme === 'dark') root.classList.add('dark');
      else root.classList.remove('dark');
      try { localStorage.setItem(STORAGE_KEY, theme); } catch (_) {}
    }

    function handleClick() {
      var isDark = document.documentElement.classList.contains('dark');
      applyTheme(isDark ? 'light' : 'dark');
    }

    function attach() {
      var buttons = document.querySelectorAll('[data-theme-toggle]');
      for (var i = 0; i < buttons.length; i++) {
        var btn = buttons[i];
        if (btn.dataset.themeAttached === 'true') continue;
        btn.dataset.themeAttached = 'true';
        btn.addEventListener('click', handleClick);
      }
    }

    attach();
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', attach);
    }
    document.addEventListener('astro:page-load', attach);
    document.addEventListener('astro:after-swap', attach);
  })();
</script>
