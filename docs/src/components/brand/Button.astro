---
/**
 * Button — DSS-pattern primitive (ported from codewithmukesh/blog).
 *
 * Aesthetic intent: confident solid surfaces, no gradients, no glassy
 * inset highlights. Primary is ink-on-paper (foreground/background flip)
 * so the brand green is reserved for accents, links, and hover treatments
 * rather than every CTA.
 *
 * Variants: primary | secondary | ghost | invert | destructive
 * Sizes:    sm | md | lg
 * States:   disabled, loading
 *
 * Renders as <a> when `href` is provided, <button> otherwise.
 */
import { Icon } from 'astro-icon/components';
import type { HTMLAttributes } from 'astro/types';

type ButtonVariant = 'primary' | 'secondary' | 'ghost' | 'invert' | 'destructive';
type ButtonSize = 'sm' | 'md' | 'lg';

type Props = (HTMLAttributes<'button'> & HTMLAttributes<'a'>) & {
  variant?: ButtonVariant;
  size?: ButtonSize;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  loading?: boolean;
  href?: string;
  class?: string;
  ariaLabel?: string;
  target?: '_self' | '_blank';
  rel?: string;
};

const {
  variant = 'primary',
  size = 'md',
  type = 'button',
  disabled = false,
  loading = false,
  href,
  class: classList,
  ariaLabel,
  target,
  rel,
  ...rest
} = Astro.props as Props;

const base =
  'inline-flex items-center justify-center gap-1.5 font-medium rounded-lg transition-all whitespace-nowrap select-none active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background disabled:pointer-events-none disabled:opacity-50';

const variants: Record<ButtonVariant, string> = {
  primary:     'bg-foreground text-background hover:bg-foreground/90',
  secondary:   'bg-card text-foreground border border-border hover:border-border-strong',
  ghost:       'text-foreground hover:bg-foreground/[0.06]',
  invert:      'bg-background text-foreground hover:bg-background/90',
  destructive: 'bg-destructive text-destructive-foreground hover:bg-destructive/90',
};

const sizes: Record<ButtonSize, string> = {
  sm: 'h-8 px-3 text-[13px]',
  md: 'h-10 px-4 text-[14px]',
  lg: 'h-11 px-5 text-[15px]',
};

const classes = `${base} ${variants[variant]} ${sizes[size]} ${classList ?? ''}`;

const Tag = href ? 'a' : 'button';
const isInteractive = !disabled && !loading;
const resolvedRel = rel ?? (target === '_blank' ? 'noopener noreferrer' : undefined);
---

<Tag
  href={href}
  type={!href ? type : undefined}
  role={href ? 'button' : undefined}
  target={href ? target : undefined}
  rel={href ? resolvedRel : undefined}
  aria-label={ariaLabel}
  aria-disabled={!isInteractive ? 'true' : undefined}
  aria-busy={loading ? 'true' : undefined}
  tabindex={!isInteractive && href ? -1 : undefined}
  class={classes}
  disabled={!href && (disabled || loading) ? true : undefined}
  {...rest}
>
  {loading && <Icon name="lucide:loader-2" class="h-4 w-4 animate-spin" />}
  <slot />
</Tag>
