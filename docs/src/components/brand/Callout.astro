---
/**
 * Callout primitive (ported from codewithmukesh/blog).
 *
 * Variants:
 *   note    — slate (neutral, low-emphasis aside)
 *   tip     — emerald (helpful guidance)
 *   warning — amber (caveat, gotcha)
 *   danger  — rose (do-not-do, breaking issue)
 *   info    — sky (general information)
 */
import { Icon } from 'astro-icon/components';

type CalloutVariant = 'note' | 'tip' | 'warning' | 'danger' | 'info';

interface Props {
  variant?: CalloutVariant;
  title?: string;
  class?: string;
}

const { variant = 'note', title, class: classList } = Astro.props as Props;

const variantConfig: Record<CalloutVariant, { wrap: string; icon: string; iconColor: string }> = {
  note: {
    wrap: 'bg-slate-50 border-slate-200 dark:bg-slate-900 dark:border-slate-800',
    icon: 'lucide:sticky-note',
    iconColor: 'text-slate-500 dark:text-slate-400',
  },
  tip: {
    wrap: 'bg-emerald-50 border-emerald-200 dark:bg-emerald-500/10 dark:border-emerald-500/25',
    icon: 'lucide:lightbulb',
    iconColor: 'text-emerald-600 dark:text-emerald-400',
  },
  warning: {
    wrap: 'bg-amber-50 border-amber-200 dark:bg-amber-500/10 dark:border-amber-500/25',
    icon: 'lucide:alert-triangle',
    iconColor: 'text-amber-600 dark:text-amber-400',
  },
  danger: {
    wrap: 'bg-rose-50 border-rose-200 dark:bg-rose-500/10 dark:border-rose-500/25',
    icon: 'lucide:octagon-x',
    iconColor: 'text-rose-600 dark:text-rose-400',
  },
  info: {
    wrap: 'bg-sky-50 border-sky-200 dark:bg-sky-500/10 dark:border-sky-500/25',
    icon: 'lucide:info',
    iconColor: 'text-sky-600 dark:text-sky-400',
  },
};

const cfg = variantConfig[variant];
---

<aside
  role="note"
  class:list={['rounded-lg border p-4 my-6 flex gap-3', cfg.wrap, classList]}
>
  <Icon name={cfg.icon} class:list={['h-5 w-5 shrink-0 mt-0.5', cfg.iconColor]} />
  <div class="flex-1 min-w-0">
    {title && <div class="font-semibold tracking-tight mb-1">{title}</div>}
    <div class="text-sm leading-relaxed [&>p]:my-0 [&>p+p]:mt-2">
      <slot />
    </div>
  </div>
</aside>
