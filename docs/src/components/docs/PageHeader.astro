---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  pageType: 'guide' | 'reference' | 'concept' | 'recipe';
  lastUpdated?: Date;
}

const { title, description, pageType, lastUpdated } = Astro.props;
const typeLabel = {
  guide: 'Guide',
  reference: 'Reference',
  concept: 'Concept',
  recipe: 'Recipe',
}[pageType];

// Dev: render the chip in its `ready` state with a sample value so the UI is
// visible under `astro dev` (the Worker isn't running, so the beacon 404s).
// Prod: render in `pending` state; the client beacon flips it to `ready` only
// on a successful response. `pending` keeps the chip in the layout (via
// visibility:hidden) so revealing it doesn't reflow the row.
const isDev = import.meta.env.DEV;
const initialState = isDev ? 'ready' : 'pending';
const initialCount = isDev ? '1,234' : '0';
---
<header class="mb-8 border-b border-border pb-6">
  <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-primary">{typeLabel}</p>
  <h1 class="mt-2 text-[32px] font-semibold leading-[1.15] tracking-tight">{title}</h1>
  <p class="mt-3 text-[15.5px] leading-[1.55] text-muted-foreground">{description}</p>
  <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-2 text-[11px] uppercase tracking-wider text-muted-foreground">
    {/* Views chip — editorial data readout. Borrows the split-pill motif
        from the header GitHub-stars chip, scaled to metadata. The `pending`
        state preserves layout so the reveal doesn't reflow the row. */}
    <span
      data-views-count-wrap
      data-state={initialState}
      title={isDev ? 'Sample value — run wrangler dev to see real counts' : undefined}
      class="views-chip inline-flex h-7 items-center overflow-hidden rounded-full border border-border/60 bg-card/70 normal-case tracking-normal text-foreground backdrop-blur-sm transition-colors hover:border-border-strong dark:border-border/30"
    >
      <span class="inline-flex h-full items-center gap-1.5 pl-2.5 pr-1.5 text-[11.5px] font-medium">
        <Icon name="lucide:eye" class="h-3 w-3 text-muted-foreground" aria-hidden="true" />
        <span class="text-muted-foreground">views</span>
      </span>
      <span class="inline-flex h-full items-center border-l border-border/60 bg-foreground/[0.035] px-2.5 text-[11.5px] font-semibold tabular-nums dark:border-border/30 dark:bg-foreground/[0.06]">
        <span data-views-count>{initialCount}</span>
      </span>
    </span>

    {lastUpdated && (
      <span>
        Last updated <time datetime={lastUpdated.toISOString()}>{lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
      </span>
    )}
  </div>

  <style>
    /* Reveal-from-pending: opacity + a 2px lift so the chip glides into
       place rather than pops. `visibility: hidden` (not display:none)
       reserves the layout slot — no row reflow when the beacon resolves. */
    .views-chip {
      transition:
        opacity 360ms cubic-bezier(0.32, 0.72, 0, 1),
        transform 360ms cubic-bezier(0.32, 0.72, 0, 1),
        border-color 200ms ease;
    }
    .views-chip[data-state='pending'] {
      opacity: 0;
      visibility: hidden;
      transform: translateY(2px);
    }
    .views-chip[data-state='ready'] {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .views-chip {
        transition: none;
      }
    }
  </style>
</header>
