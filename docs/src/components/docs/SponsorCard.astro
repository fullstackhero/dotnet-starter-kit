---
/**
 * Sticky sponsor card shown at the top of the docs ToC rail.
 * Pins to the top of the right rail (the aside is the scroll container) so it
 * stays visible as the page — and any long ToC — scrolls.
 */
const href = 'https://opencollective.com/fullstackhero';
---
<div class="sticky top-0 z-10 mb-4 rounded-xl border border-border bg-card">
  <div class="flex items-center gap-3 px-4 py-3">
    <svg
      class="h-3.5 w-3.5 text-primary"
      viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
    >
      <path d="M12 21s-6.7-4.35-9.33-8.04C1.1 10.7 1.6 7.4 4.1 6.04 6 5 8.2 5.6 9.6 7.2L12 9.9l2.4-2.7c1.4-1.6 3.6-2.2 5.5-1.16 2.5 1.36 3 4.66 1.43 6.92C18.7 16.65 12 21 12 21Z" />
    </svg>
    <span class="flex-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-foreground">
      Support the project
    </span>
  </div>

  <div class="mx-4 border-t border-border/60"></div>

  <div class="px-4 py-3.5">
    <p class="text-[12.5px] leading-relaxed text-muted-foreground">
      fullstackhero is free and open source. Sponsorships fund active maintenance, docs, and new features.
    </p>
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-flex w-full items-center justify-center gap-2 rounded-lg bg-primary px-3.5 py-2 text-[13px] font-semibold text-primary-foreground transition-colors hover:bg-primary-hover"
    >
      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 21s-6.7-4.35-9.33-8.04C1.1 10.7 1.6 7.4 4.1 6.04 6 5 8.2 5.6 9.6 7.2L12 9.9l2.4-2.7c1.4-1.6 3.6-2.2 5.5-1.16 2.5 1.36 3 4.66 1.43 6.92C18.7 16.65 12 21 12 21Z" />
      </svg>
      Sponsor
    </a>
  </div>
</div>
