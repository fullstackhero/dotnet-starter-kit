---
/**
 * Search modal — Pagefind-powered.
 * Trigger via Ctrl/Cmd+K or by calling window.openSearchModal().
 *
 * Pagefind index is generated post-build at /pagefind/. In dev, the index
 * doesn't exist yet (we don't run pagefind on dev), so the modal opens but
 * shows "search is unavailable in dev — run npm run build && npm run preview".
 */
---
<div
  id="search-modal"
  class="fixed inset-0 z-modal pointer-events-none opacity-0 transition-opacity duration-150"
  data-search-modal
  aria-hidden="true"
>
  <button
    type="button"
    class="absolute inset-0 bg-foreground/40 backdrop-blur-sm"
    aria-label="Close search"
    data-search-close
    tabindex="-1"
  ></button>
  <div
    role="dialog"
    aria-modal="true"
    aria-label="Search docs"
    class="absolute left-1/2 top-20 w-[min(92vw,640px)] -translate-x-1/2 overflow-hidden rounded-xl border border-border bg-card shadow-2xl"
  >
    <div class="flex items-center gap-3 border-b border-border px-4 py-3">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted-foreground" aria-hidden="true">
        <circle cx="11" cy="11" r="8"></circle>
        <path stroke-linecap="round" d="m21 21-4.35-4.35"></path>
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder="Search docs…"
        autocomplete="off"
        class="flex-1 bg-transparent text-sm outline-none placeholder:text-muted-foreground"
        data-search-input
      />
      <kbd class="hidden rounded border border-border bg-muted/40 px-1.5 py-0.5 font-mono text-[10px] text-muted-foreground sm:inline-flex">Esc</kbd>
    </div>
    <div data-search-results class="max-h-[60vh] overflow-y-auto p-2 text-sm">
      <p class="px-3 py-6 text-center text-muted-foreground" data-search-empty>Type to search…</p>
    </div>
  </div>
</div>

<script>
  type PagefindResult = {
    id: string;
    data: () => Promise<{
      url: string;
      meta?: { title?: string };
      excerpt: string;
    }>;
  };

  type PagefindAPI = {
    search: (query: string) => Promise<{ results: PagefindResult[] }>;
  };

  declare global {
    interface Window {
      openSearchModal?: () => void;
    }
  }

  let pagefind: PagefindAPI | null = null;
  let pagefindLoadAttempted = false;

  async function loadPagefind(): Promise<PagefindAPI | null> {
    if (pagefind) return pagefind;
    if (pagefindLoadAttempted) return null;
    pagefindLoadAttempted = true;
    try {
      // /pagefind/pagefind.js is generated by the pagefind CLI post-build.
      // The `new Function` indirection hides the import from rollup so it
      // doesn't try to resolve at build time.
      const dynamicImport = new Function('u', 'return import(u)') as (u: string) => Promise<unknown>;
      const mod = await dynamicImport('/pagefind/pagefind.js');
      pagefind = mod as PagefindAPI;
      return pagefind;
    } catch {
      return null;
    }
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  function setupSearch() {
    const modal = document.querySelector<HTMLElement>('[data-search-modal]');
    const input = document.querySelector<HTMLInputElement>('[data-search-input]');
    const results = document.querySelector<HTMLElement>('[data-search-results]');
    const closes = document.querySelectorAll<HTMLElement>('[data-search-close]');
    if (!modal || !input || !results) return;

    function open() {
      if (!modal) return;
      modal.classList.remove('pointer-events-none', 'opacity-0');
      modal.classList.add('pointer-events-auto', 'opacity-100');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      setTimeout(() => input?.focus(), 50);
    }
    function close() {
      if (!modal) return;
      modal.classList.add('pointer-events-none', 'opacity-0');
      modal.classList.remove('pointer-events-auto', 'opacity-100');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (input) input.value = '';
      if (results) results.innerHTML = '<p class="px-3 py-6 text-center text-muted-foreground">Type to search…</p>';
    }

    window.openSearchModal = open;
    closes.forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        open();
      } else if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') {
        e.preventDefault();
        close();
      }
    });

    let debounce: ReturnType<typeof setTimeout> | undefined;
    input.addEventListener('input', () => {
      const query = input.value.trim();
      clearTimeout(debounce);
      if (!query) {
        results.innerHTML = '<p class="px-3 py-6 text-center text-muted-foreground">Type to search…</p>';
        return;
      }
      debounce = setTimeout(async () => {
        const pf = await loadPagefind();
        if (!pf) {
          results.innerHTML = '<p class="px-3 py-6 text-center text-muted-foreground">Search index not available. Run <code class="font-mono">npm run build</code> first.</p>';
          return;
        }
        const search = await pf.search(query);
        if (search.results.length === 0) {
          results.innerHTML = '<p class="px-3 py-6 text-center text-muted-foreground">No results for "' + escapeHtml(query) + '".</p>';
          return;
        }
        const top = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));
        results.innerHTML = top
          .map(
            (item) => `
              <a href="${escapeHtml(item.url)}" class="block rounded-md px-3 py-2 hover:bg-muted">
                <div class="text-sm font-medium">${escapeHtml(item.meta?.title ?? item.url)}</div>
                <div class="mt-0.5 line-clamp-2 text-xs text-muted-foreground">${item.excerpt}</div>
              </a>
            `,
          )
          .join('');
      }, 150);
    });
  }

  setupSearch();
  document.addEventListener('astro:after-swap', setupSearch);
</script>
