---
/**
 * Screenshot — placeholder for in-progress documentation.
 *
 * Usage in MDX:
 *   <Screenshot src="/screenshots/admin/login.png"
 *               alt="Admin console login screen"
 *               caption="Tenant selector + email/password fields." />
 *
 * Behaviour:
 *   - If `src` is provided AND the asset exists at build time, renders a
 *     real <img> with caption (any environment).
 *   - Otherwise:
 *       • dev (`astro dev`): styled placeholder box so the author sees
 *         which screenshot still needs to be captured + the target path
 *         to drop it at.
 *       • production (`astro build`): renders nothing. Missing screenshots
 *         shouldn't leak placeholder boxes into shipped docs.
 *
 * Authors capture, drop into docs/public/screenshots/, and the placeholder
 * flips to a real image on the next build — no MDX edits required.
 */
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  /** Path under docs/public/, e.g. "/screenshots/admin/login.png". */
  src?: string;
  /** Required — short alt text describing what the screenshot shows. */
  alt: string;
  /** Optional caption rendered beneath the image. */
  caption?: string;
  /** Optional width hint. */
  width?: number;
  /** Optional aspect ratio for the placeholder box (e.g. "16/9", "4/3"). */
  aspect?: string;
}

const { src, alt, caption, width, aspect = '16/9' } = Astro.props as Props;

// Resolve whether the src actually exists at build time.
const publicPath = src ? path.join(process.cwd(), 'public', src.replace(/^\//, '')) : null;
const exists = publicPath ? fs.existsSync(publicPath) : false;

// Hide placeholders in production builds — missing screenshots leave no
// trace in shipped docs. Dev keeps showing them so the author can see
// what's still needed.
const showPlaceholder = !exists && import.meta.env.DEV;
---

{exists && src ? (
  <figure class="my-8 not-prose">
    <img
      src={src}
      alt={alt}
      width={width}
      loading="lazy"
      decoding="async"
      class="block w-full rounded-lg border border-border shadow-lg"
    />
    {caption && (
      <figcaption class="mt-3 text-center text-[13px] text-muted-foreground">
        {caption}
      </figcaption>
    )}
  </figure>
) : showPlaceholder ? (
  <figure class="my-8 not-prose">
    <div
      class="screenshot-placeholder flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-border-strong bg-subtle/40 px-6 py-10 text-center"
      style={`aspect-ratio: ${aspect};`}
      role="img"
      aria-label={alt}
    >
      <span class="mb-2 inline-flex h-9 w-9 items-center justify-center rounded-full bg-card text-muted-foreground">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <circle cx="9" cy="12" r="2.5" />
          <path d="M21 15l-4-4-7 7" />
        </svg>
      </span>
      <p class="font-mono text-[10.5px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
        Screenshot placeholder
      </p>
      <p class="mt-2 max-w-md font-display text-[15px] font-semibold tracking-[-0.01em] text-foreground">
        {alt}
      </p>
      {caption && (
        <p class="mt-1 max-w-md text-[13px] text-muted-foreground">
          {caption}
        </p>
      )}
      {src && (
        <p class="mt-3 font-mono text-[11px] text-muted-foreground/70">
          Drop image at <code>public{src}</code>
        </p>
      )}
    </div>
  </figure>
) : null}
