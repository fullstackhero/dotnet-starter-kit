---
import Landing from '../layouts/Landing.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import mukeshPhoto from '../assets/mukesh_murugan.png';
---

<Landing title="fullstackhero - .NET Starter Kit" description="A production-ready modular .NET framework for building enterprise applications.">
	<Nav />

	<!-- ════ HERO ════ -->
	<section class="hero">
		<div class="hero-constellation" aria-hidden="true"></div>
		<div class="hero-glow" aria-hidden="true"></div>
		<div class="w">
			<div class="hero-center">
				<a href="/dotnet-starter-kit/quick-start/" class="hero-pill">
					<span class="pill-glow"></span>
					<span class="pill-badge"><span class="pulse"></span>v10.0</span>
					<span class="pill-text">.NET 10 &bull; C# latest &bull; Aspire</span>
					<svg class="pill-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4.5 3l3 3-3 3"/></svg>
				</a>
				<h1>Build fast.<br /><span class="g">Ship faster.</span></h1>
				<p class="hero-p">
					Production-ready .NET starter kit with multitenancy, identity, CQRS,<br class="br-desk" />
					and vertical slice architecture. Stop re-wiring plumbing.
				</p>
				<div class="hero-row">
					<a href="/dotnet-starter-kit/quick-start/" class="btn">Get Started</a>
					<a href="https://github.com/fullstackhero/dotnet-starter-kit" target="_blank" rel="noopener" class="btn btn-o">
						<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
						GitHub
					</a>
				</div>
			</div>

			<!-- terminal below -->
			<div class="hero-term-wrap">
				<div class="hero-term">
					<div class="ht-bar">
						<span class="ht-dot ht-r"></span>
						<span class="ht-dot ht-y"></span>
						<span class="ht-dot ht-g"></span>
					</div>
					<div class="ht-body" id="hero-term-body">
						<div class="ht-line" data-type data-delay="300"><span class="ht-p">~</span> <span class="ht-comment"># clone &amp; run in 60 seconds</span></div>
						<div class="ht-line" data-type data-delay="600"><span class="ht-p">~</span> git clone https://github.com/fullstackhero/dotnet-starter-kit</div>
						<div class="ht-line" data-type data-delay="900"><span class="ht-p">~</span> cd dotnet-starter-kit</div>
						<div class="ht-line" data-type data-delay="1100"><span class="ht-p">~</span> dotnet run <span class="ht-flag">--project</span> src/Host/FSH.Api</div>
						<div class="ht-blank"></div>
						<div class="ht-line ht-out" data-type data-delay="1600"><span class="ht-ok">info:</span> Now listening on <span class="ht-url">https://localhost:5001</span></div>
						<div class="ht-line ht-out" data-type data-delay="1900"><span class="ht-ok">info:</span> Scalar docs at <span class="ht-url">localhost:5001/scalar/v1</span></div>
					</div>
					<div class="ht-footer">
						<a href="/dotnet-starter-kit/quick-start/" class="ht-link">
							Read the full guide
							<svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M2.5 6h7M6.5 3l3 3-3 3"/></svg>
						</a>
						<a href="https://github.com/fullstackhero/dotnet-starter-kit" target="_blank" rel="noopener" class="ht-stars">
							<svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0l2.5 5 5.5.8-4 3.9.9 5.3L8 12.5 3.1 15l.9-5.3-4-3.9L5.5 5z"/></svg>
							6.3k
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ════ NUMBERS ════ -->
	<section class="nums">
		<div class="w">
			<div class="nums-strip">
				<div class="ns">
					<svg width="16" height="16" viewBox="0 0 16 16" fill="var(--brand)"><path d="M8 0l2.5 5 5.5.8-4 3.9.9 5.3L8 12.5 3.1 15l.9-5.3-4-3.9L5.5 5z"/></svg>
					<span class="ns-val">6.3k+</span>
					<span class="ns-label">stars</span>
				</div>
				<div class="ns">
					<svg width="16" height="16" viewBox="0 0 16 16" fill="var(--text-faint)"><path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75v-.878a2.25 2.25 0 111.5 0v.878a2.25 2.25 0 01-2.25 2.25h-1.5v2.128a2.251 2.251 0 11-1.5 0V8.5h-1.5A2.25 2.25 0 013.5 6.25v-.878a2.25 2.25 0 111.5 0zM5 3.25a.75.75 0 10-1.5 0 .75.75 0 001.5 0zm6.75.75a.75.75 0 100-1.5.75.75 0 000 1.5zM8 12.25a.75.75 0 10-1.5 0 .75.75 0 001.5 0z"/></svg>
					<span class="ns-val">1.9k+</span>
					<span class="ns-label">forks</span>
				</div>
				<div class="ns">
					<svg width="16" height="16" viewBox="0 0 16 16" fill="var(--text-faint)"><path d="M1.5 14.25c0 .138.112.25.25.25H4v-1.25a.75.75 0 01.75-.75h2.5a.75.75 0 01.75.75v1.25h2.25a.25.25 0 00.25-.25V1.75a.25.25 0 00-.25-.25h-8.5a.25.25 0 00-.25.25v12.5zM1.75 16A1.75 1.75 0 010 14.25V1.75C0 .784.784 0 1.75 0h8.5C11.216 0 12 .784 12 1.75v12.5c0 .085-.006.168-.018.25h2.268a.25.25 0 00.25-.25V8.285a.25.25 0 00-.111-.208l-1.055-.703a.75.75 0 11.832-1.248l1.064.71c.487.325.768.862.768 1.415v5.999A1.75 1.75 0 0114.25 16H1.75zM3.5 3.75a.75.75 0 01.75-.75h3a.75.75 0 010 1.5h-3a.75.75 0 01-.75-.75zM3.5 6a.75.75 0 01.75-.75h3a.75.75 0 010 1.5h-3A.75.75 0 013.5 6z"/></svg>
					<span class="ns-val">50+</span>
					<span class="ns-label">contributors</span>
				</div>
				<div class="ns">
					<svg width="16" height="16" viewBox="0 0 16 16" fill="var(--text-faint)"><path d="M8 0a8 8 0 100 16A8 8 0 008 0zM1.5 8a6.5 6.5 0 1113 0 6.5 6.5 0 01-13 0zM8 3.25a.75.75 0 01.75.75v3.25H11a.75.75 0 010 1.5H7.25V4A.75.75 0 018 3.25z"/></svg>
					<span class="ns-val">5 yrs</span>
					<span class="ns-label">maintained</span>
				</div>
			</div>
		</div>
	</section>

	<!-- ════ BENTO FEATURES ════ -->
	<section class="bento" id="features" data-reveal>
		<div class="w">
			<div class="sec-hd sec-hd-c">
				<span class="sec-tag">Features</span>
				<h2>Everything wired.<br />Nothing wasted.</h2>
				<p class="sec-sub">A framework, not a template. Every piece is built to work together.</p>
			</div>
			<div class="bento-grid" data-reveal-stagger>
				<!-- row 1: wide -->
				<div class="b-card b-span2 b-accent">
					<div class="b-inner">
						<span class="b-label">Architecture</span>
						<h3>Modular Monolith + Vertical Slices</h3>
						<p>Isolated modules. Enforced contracts. Each feature is one folder - endpoint, handler, validator. Architecture tests verify boundaries at build time.</p>
					</div>
					<div class="b-visual">
						<div class="b-tree">
							<div class="bt-folder"><span class="bt-icon">+</span> Features/v1/Users/RegisterUser</div>
							<div class="bt-file">RegisterUserEndpoint.cs</div>
							<div class="bt-file">RegisterUserCommandHandler.cs</div>
							<div class="bt-file">RegisterUserCommandValidator.cs</div>
						</div>
					</div>
				</div>

				<!-- row 2: two cards -->
				<div class="b-card">
					<span class="b-label">Tenancy</span>
					<h3>Multitenancy</h3>
					<p>Finbuckle-powered. Resolves via JWT claims, HTTP headers, or query strings. EF Core queries auto-scope to the current tenant.</p>
					<div class="b-tag-row"><code>IHasTenant</code><code>ClaimStrategy</code><code>HeaderStrategy</code></div>
				</div>
				<div class="b-card">
					<span class="b-label">Auth</span>
					<h3>Identity & Permissions</h3>
					<p>JWT Bearer + ASP.NET Identity. Fine-grained permission constants. Applied to endpoints with one method call.</p>
					<div class="b-tag-row"><code>.RequirePermission()</code></div>
				</div>

				<!-- row 3: two cards -->
				<div class="b-card">
					<span class="b-label">CQRS</span>
					<h3>Source-Gen Mediator</h3>
					<p>Zero-reflection, zero-allocation command/query dispatch. Contracts in public projects, handlers private to the module.</p>
					<div class="b-tag-row"><code>ICommand&lt;T&gt;</code><code>IQuery&lt;T&gt;</code><code>ValueTask</code></div>
				</div>
				<div class="b-card">
					<span class="b-label">Data</span>
					<h3>EF Core + PostgreSQL</h3>
					<p>Code-first migrations, soft deletes, audit trails, specification pattern, and tenant-scoped DbContext - pre-configured.</p>
					<div class="b-tag-row"><code>Npgsql</code><code>Specification&lt;T&gt;</code></div>
				</div>

				<!-- row 4: wide -->
				<div class="b-card b-span2">
					<div class="b-inner">
						<span class="b-label">Observability & Infra</span>
						<h3>Production-grade from day one</h3>
						<p>Structured logging, distributed traces, metrics collection, background jobs, and local orchestration - pre-wired so you never fly blind.</p>
					</div>
					<div class="b-stack-pills">
						<div class="bsp"><span class="bsp-dot bsp-g"></span>Serilog</div>
						<div class="bsp"><span class="bsp-dot bsp-b"></span>OpenTelemetry</div>
						<div class="bsp"><span class="bsp-dot bsp-r"></span>Redis</div>
						<div class="bsp"><span class="bsp-dot bsp-y"></span>Hangfire</div>
						<div class="bsp"><span class="bsp-dot bsp-p"></span>Aspire</div>
						<div class="bsp"><span class="bsp-dot bsp-g"></span>Scalar</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ════ NEWSLETTER ════ -->
	<section class="nl-sec" data-reveal>
		<div class="w">
			<div class="nl-outer">
				<div class="nl-glow" aria-hidden="true"></div>
				<div class="nl-dots" aria-hidden="true"></div>

				<div class="nl-content">
					<div class="nl-text">
						<span class="sec-tag">Newsletter</span>
						<h2 class="nl-h2">Level up your .NET game.<br />Every Tuesday.</h2>
						<p class="nl-p">
							Practical architecture patterns, production tips, deep dives into EF Core,
							CQRS, modular monoliths, and fullstackhero updates - straight to your inbox.
						</p>

						<div class="nl-perks">
							<div class="nl-perk">
								<svg width="16" height="16" viewBox="0 0 16 16" fill="var(--brand)"><path d="M8 0a8 8 0 100 16A8 8 0 008 0zm3.78 5.28l-4.5 5.5a.75.75 0 01-1.1.06l-2.5-2.25a.75.75 0 011-1.12l1.91 1.72 3.99-4.87a.75.75 0 011.2.96z"/></svg>
								<span>Real-world .NET patterns, not theory</span>
							</div>
							<div class="nl-perk">
								<svg width="16" height="16" viewBox="0 0 16 16" fill="var(--brand)"><path d="M8 0a8 8 0 100 16A8 8 0 008 0zm3.78 5.28l-4.5 5.5a.75.75 0 01-1.1.06l-2.5-2.25a.75.75 0 011-1.12l1.91 1.72 3.99-4.87a.75.75 0 011.2.96z"/></svg>
								<span>Early access to fullstackhero releases</span>
							</div>
							<div class="nl-perk">
								<svg width="16" height="16" viewBox="0 0 16 16" fill="var(--brand)"><path d="M8 0a8 8 0 100 16A8 8 0 008 0zm3.78 5.28l-4.5 5.5a.75.75 0 01-1.1.06l-2.5-2.25a.75.75 0 011-1.12l1.91 1.72 3.99-4.87a.75.75 0 011.2.96z"/></svg>
								<span>One email a week. Unsubscribe anytime.</span>
							</div>
						</div>
					</div>

					<div class="nl-form-wrap">
						<div class="nl-form-card">
							<div class="nl-form-header">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4l-10 8L2 4"/></svg>
								<span>codewithmukesh</span>
							</div>
							<form class="nl-form" action="#" method="post" id="nl-form">
								<label class="nl-label" for="nl-name">Name</label>
								<input type="text" id="nl-name" name="name" placeholder="Your name" class="nl-input" />

								<label class="nl-label" for="nl-email">Email</label>
								<input type="email" id="nl-email" name="email" placeholder="you@company.com" required class="nl-input" />

								<button type="submit" class="nl-btn">
									Subscribe
									<svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
								</button>
							</form>
							<p class="nl-proof">
								<svg width="12" height="12" viewBox="0 0 16 16" fill="var(--text-faint)"><path d="M8 1a7 7 0 100 14A7 7 0 008 1zm0 2.5a1 1 0 110 2 1 1 0 010-2zm2 8h-4v-1h1.25V7.75H6v-1h2.25v3.75H9.5v1z"/></svg>
								<span>6,500+ subscribers. Read by developers at Microsoft, AWS, and startups worldwide.</span>
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ════ ARCHITECTURE ════ -->
	<section class="arch" data-reveal>
		<div class="w">
			<div class="sec-hd sec-hd-c">
				<span class="sec-tag">Architecture</span>
				<h2>Modular Monolith meets<br />Vertical Slice Architecture.</h2>
				<p class="sec-sub">Modules own their boundaries. Features own their slices. Architecture tests enforce both at build time.</p>
			</div>

			<div class="arch-panels">
				<!-- LEFT: Modular Monolith -->
				<div class="arch-panel">
					<div class="ap-header">
						<span class="ap-badge ap-badge-g">Modular Monolith</span>
						<span class="ap-desc">Bounded contexts as modules. Contracts as the only interface.</span>
					</div>

					<div class="ap-modules">
						<!-- Module: Identity -->
						<div class="ap-mod">
							<div class="ap-mod-head">
								<span class="ap-mod-dot" style="background:#4ade80"></span>
								<span class="ap-mod-name">Identity</span>
								<span class="ap-mod-type">module</span>
							</div>
							<div class="ap-mod-body">
								<div class="ap-mod-col">
									<span class="ap-col-label">Runtime</span>
									<span class="ap-file">Features/</span>
									<span class="ap-file">Domain/</span>
									<span class="ap-file">Data/</span>
								</div>
								<div class="ap-mod-sep"></div>
								<div class="ap-mod-col">
									<span class="ap-col-label">Contracts</span>
									<span class="ap-file">Commands/</span>
									<span class="ap-file">Queries/</span>
									<span class="ap-file">DTOs/</span>
								</div>
							</div>
						</div>

						<!-- Module: Multitenancy -->
						<div class="ap-mod">
							<div class="ap-mod-head">
								<span class="ap-mod-dot" style="background:#38bdf8"></span>
								<span class="ap-mod-name">Multitenancy</span>
								<span class="ap-mod-type">module</span>
							</div>
							<div class="ap-mod-body">
								<div class="ap-mod-col">
									<span class="ap-col-label">Runtime</span>
									<span class="ap-file">Features/</span>
									<span class="ap-file">Domain/</span>
									<span class="ap-file">Data/</span>
								</div>
								<div class="ap-mod-sep"></div>
								<div class="ap-mod-col">
									<span class="ap-col-label">Contracts</span>
									<span class="ap-file">Commands/</span>
									<span class="ap-file">Queries/</span>
									<span class="ap-file">DTOs/</span>
								</div>
							</div>
						</div>

						<!-- Module: Auditing -->
						<div class="ap-mod">
							<div class="ap-mod-head">
								<span class="ap-mod-dot" style="background:#fbbf24"></span>
								<span class="ap-mod-name">Auditing</span>
								<span class="ap-mod-type">module</span>
							</div>
							<div class="ap-mod-body">
								<div class="ap-mod-col">
									<span class="ap-col-label">Runtime</span>
									<span class="ap-file">Features/</span>
									<span class="ap-file">Domain/</span>
									<span class="ap-file">Data/</span>
								</div>
								<div class="ap-mod-sep"></div>
								<div class="ap-mod-col">
									<span class="ap-col-label">Contracts</span>
									<span class="ap-file">Events/</span>
									<span class="ap-file">DTOs/</span>
								</div>
							</div>
						</div>
					</div>

					<!-- Contract rule -->
					<div class="ap-rule">
						<div class="ap-rule-line"></div>
						<div class="ap-rule-badge">
							<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1v10M1 6h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
							Module A references Module B<strong>.Contracts</strong> only
						</div>
						<div class="ap-rule-line"></div>
					</div>

					<!-- Shared layer -->
					<div class="ap-shared">
						<span class="ap-shared-label">BuildingBlocks</span>
						<div class="ap-shared-items">
							<span>Core</span><span>Persistence</span><span>Web</span><span>Caching</span><span>Eventing</span><span>Auth</span>
						</div>
					</div>
				</div>

				<!-- RIGHT: Vertical Slice -->
				<div class="arch-panel">
					<div class="ap-header">
						<span class="ap-badge ap-badge-b">Vertical Slice Architecture</span>
						<span class="ap-desc">Each feature is one folder. No scattered layers to navigate.</span>
					</div>

					<!-- VSA Diagram -->
					<div class="vsa-diagram">
						<div class="vsa-request">
							<span class="vsa-req-method">POST</span>
							<span class="vsa-req-path">/api/v1/users/register</span>
						</div>

						<div class="vsa-arrow">
							<svg width="2" height="24" viewBox="0 0 2 24"><line x1="1" y1="0" x2="1" y2="24" stroke="var(--brand)" stroke-width="1.5" stroke-dasharray="4 3"/></svg>
						</div>

						<div class="vsa-slice">
							<div class="vsa-slice-header">
								<span class="vsa-folder-icon">
									<svg width="14" height="14" viewBox="0 0 16 16" fill="var(--brand)"><path d="M1.5 2A1.5 1.5 0 000 3.5v9A1.5 1.5 0 001.5 14h13a1.5 1.5 0 001.5-1.5V5a1.5 1.5 0 00-1.5-1.5H7.707l-.854-.853A.5.5 0 006.5 2.5H1.5z"/></svg>
								</span>
								<span class="vsa-slice-path">Features/v1/Users/RegisterUser/</span>
							</div>

							<div class="vsa-files">
								<div class="vsa-file">
									<div class="vsa-file-head">
										<span class="vsa-file-icon vfi-green"></span>
										<span class="vsa-file-name">RegisterUserEndpoint.cs</span>
									</div>
									<div class="vsa-file-desc">Route + HTTP method + OpenAPI metadata</div>
								</div>
								<div class="vsa-file">
									<div class="vsa-file-head">
										<span class="vsa-file-icon vfi-blue"></span>
										<span class="vsa-file-name">RegisterUserCommand.cs</span>
									</div>
									<div class="vsa-file-desc">Command DTO in Contracts project</div>
								</div>
								<div class="vsa-file">
									<div class="vsa-file-head">
										<span class="vsa-file-icon vfi-purple"></span>
										<span class="vsa-file-name">RegisterUserHandler.cs</span>
									</div>
									<div class="vsa-file-desc">Business logic + persistence</div>
								</div>
								<div class="vsa-file">
									<div class="vsa-file-head">
										<span class="vsa-file-icon vfi-amber"></span>
										<span class="vsa-file-name">RegisterUserValidator.cs</span>
									</div>
									<div class="vsa-file-desc">FluentValidation rules (auto-registered)</div>
								</div>
							</div>
						</div>

						<div class="vsa-arrow">
