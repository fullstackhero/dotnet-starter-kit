<style is:global>
	/* ── util ─────────────────────── */
	.w { max-width: 80rem; margin: 0 auto; padding: 0 2rem; }
	.br-desk { display: inline; }

	/* Prevent horizontal overflow from absolute-positioned decorative elements */
	html { overflow-x: hidden; }

	/* ── HERO ─────────────────────── */
	.hero {
		position: relative; padding: 8rem 0 2rem; overflow: hidden;
	}

	/* particle constellation */
	.hero-constellation {
		position: absolute; inset: 0; z-index: 0; overflow: hidden;
		pointer-events: none;
	}
