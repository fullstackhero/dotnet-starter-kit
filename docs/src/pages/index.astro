	}

	/* ── FAQ SMOOTH ACCORDION ────── */
	/* Use grid rows for smooth height: 0fr -> 1fr is GPU friendly */
	.faq-item .faq-answer {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.4s ease-out;
