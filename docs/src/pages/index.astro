<script>
	// ── Scroll Reveal (IntersectionObserver) ──
	const revealEls = document.querySelectorAll('[data-reveal], [data-reveal-stagger]');
	if (revealEls.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		const revealObserver = new IntersectionObserver((entries) => {
			entries.forEach(e => {
				if (e.isIntersecting) {
					e.target.classList.add('visible');
					revealObserver.unobserve(e.target);
				}
			});
		}, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
		revealEls.forEach(el => revealObserver.observe(el));
	} else {
		// Reduced motion or no elements: show everything immediately
		revealEls.forEach(el => el.classList.add('visible'));
	}

	// ── Terminal Typing Animation ──
	const typeLines = document.querySelectorAll('.ht-line[data-type]');
	if (typeLines.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		typeLines.forEach(line => {
			const delay = parseInt(line.getAttribute('data-delay') || '0', 10);
			setTimeout(() => line.classList.add('typed'), delay);
		});
	} else {
		typeLines.forEach(line => {
			line.style.width = 'auto';
			line.style.opacity = '1';
			if (line.classList.contains('ht-out')) line.style.opacity = '0.6';
		});
	}

	// ── FAQ Smooth Close ──
	// The grid-rows transition handles opening. For closing, we need to
	// prevent instant close so the 0fr transition can play out.
	document.querySelectorAll('.faq-item').forEach(item => {
		const summary = item.querySelector('summary');
		if (!summary) return;
		summary.addEventListener('click', (e) => {
			if (item.open) {
				e.preventDefault();
				item.classList.add('closing');
				const answer = item.querySelector('.faq-answer');
				if (answer) {
					(answer as HTMLElement).style.gridTemplateRows = '0fr';
					const p = answer.querySelector('p');
					if (p) (p as HTMLElement).style.opacity = '0';
				}
				setTimeout(() => {
					item.open = false;
					item.classList.remove('closing');
					if (answer) {
						(answer as HTMLElement).style.removeProperty('grid-template-rows');
						const p = answer.querySelector('p');
						if (p) (p as HTMLElement).style.removeProperty('opacity');
					}
				}, 400);
			}
		});
	});

	// ── Particle Constellation ──
	(function () {
		const box = document.querySelector('.hero-constellation') as HTMLElement;
		if (!box || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const canvas = document.createElement('canvas');
		box.appendChild(canvas);
		const c = canvas.getContext('2d')!;
		if (!c) return;

		let w = 0, h = 0, dpr = 1, raf = 0;
		const LINK_DIST = 120;       // max distance to draw a line
		const PARTICLE_COUNT = 60;   // sweet spot: visible but not busy

		interface P { x: number; y: number; vx: number; vy: number; r: number; }
		let particles: P[] = [];

		function resize() {
			dpr = Math.min(devicePixelRatio || 1, 2);
			w = box.clientWidth;
			h = box.clientHeight;
			canvas.width = w * dpr;
			canvas.height = h * dpr;
			c.setTransform(dpr, 0, 0, dpr, 0, 0);
		}

		function seed() {
			particles = [];
			for (let i = 0; i < PARTICLE_COUNT; i++) {
				particles.push({
					x: Math.random() * w,
					y: Math.random() * h,
					vx: (Math.random() - 0.5) * 0.3,
					vy: (Math.random() - 0.5) * 0.3,
					r: 1 + Math.random() * 1.2,
				});
			}
		}

		resize();
		seed();
		window.addEventListener('resize', () => { resize(); seed(); });

		function draw() {
			c.clearRect(0, 0, w, h);
			const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
			const dot = isDark ? '74,222,128' : '15,23,42';    // green in dark, slate in light
			const line = isDark ? '74,222,128' : '15,23,42';

			// move
			for (const p of particles) {
				p.x += p.vx;
				p.y += p.vy;
				if (p.x < -10) p.x = w + 10;
				if (p.x > w + 10) p.x = -10;
				if (p.y < -10) p.y = h + 10;
				if (p.y > h + 10) p.y = -10;
			}

			// lines
			for (let i = 0; i < particles.length; i++) {
				for (let j = i + 1; j < particles.length; j++) {
					const dx = particles[i].x - particles[j].x;
					const dy = particles[i].y - particles[j].y;
					const dist = Math.sqrt(dx * dx + dy * dy);
					if (dist < LINK_DIST) {
						const alpha = (1 - dist / LINK_DIST) * (isDark ? 0.15 : 0.25);
						c.beginPath();
						c.moveTo(particles[i].x, particles[i].y);
						c.lineTo(particles[j].x, particles[j].y);
						c.strokeStyle = `rgba(${line},${alpha})`;
						c.lineWidth = 0.6;
						c.stroke();
					}
				}
			}

			// dots
			for (const p of particles) {
				c.beginPath();
				c.arc(p.x, p.y, p.r, 0, Math.PI * 2);
				c.fillStyle = `rgba(${dot},${isDark ? 0.25 : 0.4})`;
				c.fill();
			}

			raf = requestAnimationFrame(draw);
		}
		draw();

		// pause off-screen
		new IntersectionObserver(([e]) => {
			if (e.isIntersecting) { if (!raf) draw(); }
			else { cancelAnimationFrame(raf); raf = 0; }
		}, { threshold: 0 }).observe(box);
	})();
</script>
