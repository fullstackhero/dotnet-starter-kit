		display: flex; align-items: center; gap: 0.35rem;
		font-family: var(--mono); font-size: 0.68rem; font-weight: 500;
		color: var(--brand); white-space: nowrap;
		padding: 0.2rem 0.65rem; border-radius: 5px;
		background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.12);
	}
	.ap-rule-badge strong { font-weight: 700; }

	/* shared building blocks */
	.ap-shared {
		border: 1px solid var(--border); border-radius: 8px;
		padding: 0.6rem 0.75rem; background: var(--bg-card);
	}
	.ap-shared-label {
		display: block; font-family: var(--mono); font-size: 0.62rem; font-weight: 600;
		text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-faint);
		margin-bottom: 0.4rem;
	}
	.ap-shared-items { display: flex; gap: 0.3rem; flex-wrap: wrap; }
	.ap-shared-items span {
		font-family: var(--mono); font-size: 0.7rem;
		padding: 0.15rem 0.5rem; border-radius: 4px;
		border: 1px solid var(--border); color: var(--text-dim);
	}

	/* ── VSA diagram ──────────────── */
	.vsa-diagram {
		display: flex; flex-direction: column; align-items: center;
	}
	.vsa-arrow { display: flex; justify-content: center; padding: 0.1rem 0; }

	/* request */
	.vsa-request {
		display: inline-flex; align-items: center; gap: 0.5rem;
		padding: 0.45rem 0.85rem; border: 1px solid var(--border);
		border-radius: 8px; background: var(--bg-card);
		font-family: var(--mono); font-size: 0.78rem;
	}
	.vsa-req-method {
		font-weight: 700; color: var(--brand); font-size: 0.7rem;
		background: rgba(74,222,128,0.1); padding: 0.1rem 0.35rem; border-radius: 3px;
	}
	.vsa-req-path { color: var(--text-dim); }

	/* slice card */
	.vsa-slice {
		width: 100%; border: 1px solid var(--border); border-radius: 10px;
		overflow: hidden; background: var(--bg-card);
	}
	.vsa-slice-header {
		display: flex; align-items: center; gap: 0.45rem;
		padding: 0.55rem 0.85rem; border-bottom: 1px solid var(--border);
		background: rgba(74,222,128,0.03);
	}
	.vsa-folder-icon { display: flex; align-items: center; }
	.vsa-slice-path {
		font-family: var(--mono); font-size: 0.72rem; font-weight: 500; color: var(--brand);
	}

	/* files */
	.vsa-files { display: flex; flex-direction: column; }
	.vsa-file {
		padding: 0.55rem 0.85rem;
		border-bottom: 1px solid var(--border);
		transition: background .15s;
	}
	.vsa-file:last-child { border-bottom: 0; }
	.vsa-file:hover { background: rgba(255,255,255,0.015); }
	.vsa-file-head { display: flex; align-items: center; gap: 0.45rem; }
	.vsa-file-icon {
		width: 7px; height: 7px; border-radius: 2px; flex-shrink: 0;
	}
	.vfi-green  { background: var(--brand); }
	.vfi-blue   { background: #38bdf8; }
	.vfi-purple { background: #c084fc; }
	.vfi-amber  { background: #fbbf24; }
	.vsa-file-name {
		font-family: var(--mono); font-size: 0.78rem; font-weight: 500; color: var(--text);
	}
	.vsa-file-desc {
		font-size: 0.72rem; color: var(--text-faint); margin-top: 0.1rem; padding-left: 1.1rem;
	}

	/* result */
	.vsa-result {
		display: inline-flex; align-items: center; gap: 0.5rem;
		padding: 0.45rem 0.85rem; border: 1px solid var(--border);
		border-radius: 8px; background: var(--bg-card);
		font-family: var(--mono); font-size: 0.78rem;
	}
	.vsa-res-code {
		font-weight: 700; color: var(--brand); font-size: 0.7rem;
		background: rgba(74,222,128,0.1); padding: 0.1rem 0.35rem; border-radius: 3px;
	}
	.vsa-res-body { color: var(--text-faint); }

	/* insight */
	.vsa-insight {
		display: flex; align-items: flex-start; gap: 0.5rem;
		margin-top: 1.25rem; padding: 0.65rem 0.85rem;
		border-radius: 8px; border: 1px solid rgba(74,222,128,0.1);
		background: rgba(74,222,128,0.03);
		font-size: 0.82rem; color: var(--text-dim); line-height: 1.5;
	}
	.vsa-insight-icon { flex-shrink: 0; margin-top: 0.1rem; }

	/* ── CODE ─────────────────────── */
	.code-sec { padding: 6rem 0; border-top: 1px solid var(--border); }

	.code-layout {
		display: grid; grid-template-columns: 1fr 1.3fr; gap: 3.5rem; align-items: center;
	}
	.code-h2 {
		font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 600;
		letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 0.75rem;
	}
	.code-p {
		font-size: 0.95rem; line-height: 1.65; color: var(--text-dim);
		margin-bottom: 1.5rem;
	}
	.code-list {
		list-style: none; display: flex; flex-direction: column; gap: 0.6rem;
	}
	.code-list li {
		font-size: 0.88rem; color: var(--text-dim);
		display: flex; align-items: center; gap: 0.5rem;
	}
	.cl-check {
		color: var(--brand); font-weight: 700; font-size: 0.8rem;
		width: 1.2rem; flex-shrink: 0;
	}

	.code-block {
		border: 1px solid rgba(255,255,255,0.06);
		border-radius: 12px; overflow: hidden; background: #0c0c10;
		color: #e8e8ed;
	}
	.code-bar {
		display: flex; align-items: center; gap: 0.75rem;
		padding: 0.6rem 1rem; border-bottom: 1px solid rgba(255,255,255,0.06);
	}
	.code-dots { display: flex; gap: 5px; }
	.code-dots span {
		width: 10px; height: 10px; border-radius: 50%;
	}
	.code-dots span:nth-child(1) { background: #ef4444 !important; }
	.code-dots span:nth-child(2) { background: #eab308 !important; }
	.code-dots span:nth-child(3) { background: #22c55e !important; }
	.code-file { font-family: var(--mono); font-size: 0.72rem; color: #6e6e82; }

	.code-body { display: flex; }
	.code-lines {
		padding: 1rem 0 1rem 1rem; font-family: var(--mono); font-size: 0.78rem;
		line-height: 1.8; color: #6e6e82; text-align: right;
		user-select: none; min-width: 2.5rem; opacity: 0.5;
		border-right: 1px solid rgba(255,255,255,0.06);
	}
	.code-block pre {
		margin: 0; padding: 1rem 1.25rem;
		font-family: var(--mono); font-size: 0.78rem; line-height: 1.8;
		overflow-x: auto; flex: 1;
	}
	.code-block .c { color: var(--text-faint); }
	.code-block .k { color: #c084fc; }
	.code-block .t { color: #38bdf8; }
	.code-block .m { color: var(--brand); }
	.code-block .s { color: #fbbf24; }
	.code-block .i { color: var(--text-dim); }
	.code-block .p { color: var(--text-faint); }

	/* ── STACK ────────────────────── */
	.stack-sec { padding: 6rem 0; border-top: 1px solid var(--border); }

	.stack-grid {
		display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px;
		background: var(--border); border: 1px solid var(--border); border-radius: 12px;
		overflow: hidden;
	}
	.sg-card {
		background: var(--bg); padding: 1.5rem;
		transition: background .2s;
	}
	.sg-card:hover { background: var(--bg-card); }
	.sg-card h4 {
		font-family: var(--mono); font-size: 0.68rem; font-weight: 600;
		text-transform: uppercase; letter-spacing: 0.08em; color: var(--brand);
		margin-bottom: 1rem;
	}
	.sg-card ul { list-style: none; display: flex; flex-direction: column; gap: 0.55rem; }
	.sg-card li { font-size: 0.88rem; color: var(--text-dim); }

	/* ── CTA ──────────────────────── */
	.cta-sec { padding: 5rem 0 6rem; }

	.cta-box {
		position: relative; text-align: center;
		padding: 4.5rem 2rem; border: 1px solid var(--border);
		border-radius: 20px; background: var(--bg-card); overflow: hidden;
	}
	.cta-glow {
		position: absolute; top: -6rem; left: 50%; transform: translateX(-50%);
		width: 32rem; height: 18rem;
		background: radial-gradient(ellipse, var(--brand-glow) 0%, transparent 70%);
		filter: blur(50px); pointer-events: none;
	}
	.cta-grid-bg {
		position: absolute; inset: 0;
		background-image: radial-gradient(circle, rgba(74,222,128,0.04) 1px, transparent 1px);
		background-size: 24px 24px;
		mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, #000 20%, transparent 70%);
		-webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, #000 20%, transparent 70%);
		pointer-events: none;
	}

	.cta-box h2 {
		position: relative; font-size: clamp(1.6rem, 3vw, 2.2rem);
		font-weight: 600; letter-spacing: -0.02em; margin-bottom: 0.4rem;
	}
	.cta-box > p {
		position: relative; color: var(--text-dim); font-size: 1rem; margin-bottom: 2rem;
	}

	.cta-term {
		position: relative; max-width: 40rem; margin: 0 auto 2.5rem;
		border: 1px solid rgba(255,255,255,0.06); border-radius: 10px;
		background: #0a0a0d; text-align: left; overflow: hidden; color: #e8e8ed;
	}
	.cta-term-bar {
		display: flex; align-items: center; gap: 5px;
		padding: 0.55rem 0.85rem; border-bottom: 1px solid rgba(255,255,255,0.06);
	}
	.ctt-dot {
		width: 9px; height: 9px; border-radius: 50%;
	}
	.ctt-dot:nth-child(1) { background: #ef4444; }
	.ctt-dot:nth-child(2) { background: #eab308; }
	.ctt-dot:nth-child(3) { background: #22c55e; }
	.ctt-title {
		margin-left: 0.5rem; font-family: var(--mono); font-size: 0.68rem;
		color: #6e6e82;
	}
	.cta-term pre {
		margin: 0; padding: 1rem 1.25rem;
		font-family: var(--mono); font-size: 0.8rem; line-height: 1.85;
		overflow-x: auto;
	}
	.td { color: #6e6e82; }
	.tg { color: #4ade80; }
	.tu { color: #a8a8b8; text-decoration: underline; text-decoration-color: #6e6e82; }

	.cta-btns {
		position: relative;
		display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap;
	}
	.btn-lg { padding: 0.65rem 1.5rem; font-size: 0.9rem; }

	/* ── DIY COST ────────────────── */
	.diy { padding: 6rem 0; border-top: 1px solid var(--border); }

	.diy-grid {
		display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
		background: var(--border); border: 1px solid var(--border); border-radius: 12px;
		overflow: hidden; margin-bottom: 2rem;
	}
	.diy-card {
		background: var(--bg); padding: 1.5rem;
		transition: background .2s;
	}
	.diy-card:hover { background: var(--bg-card); }
	.diy-weeks {
		display: inline-block; font-family: var(--mono); font-size: 0.7rem; font-weight: 600;
		color: #f87171; background: rgba(248,113,113,0.08);
		padding: 0.15rem 0.5rem; border-radius: 4px;
		border: 1px solid rgba(248,113,113,0.12); margin-bottom: 0.6rem;
	}
	.diy-card h4 {
		font-size: 0.95rem; font-weight: 700; margin-bottom: 0.35rem;
		letter-spacing: -0.01em;
	}
	.diy-card p { font-size: 0.82rem; line-height: 1.6; color: var(--text-dim); }

	.diy-total {
		border: 1px solid var(--border); border-radius: 12px;
		background: var(--bg-card); overflow: hidden;
	}
	.diy-total-inner {
		display: flex; align-items: center;
	}
	.diy-total-left, .diy-total-right {
		flex: 1; padding: 1.75rem 2rem; text-align: center;
	}
	.diy-total-vs {
		font-size: 0.82rem; font-weight: 700; color: var(--text-faint);
		text-transform: uppercase; letter-spacing: 0.08em;
		padding: 0 0.5rem; flex-shrink: 0;
	}
	.diy-total-label {
		display: block; font-family: var(--mono); font-size: 0.68rem; font-weight: 600;
		text-transform: uppercase; letter-spacing: 0.08em;
		color: var(--text-faint); margin-bottom: 0.35rem;
	}
	.diy-total-val {
		display: block; font-size: 1.75rem; font-weight: 600;
		letter-spacing: -0.03em; margin-bottom: 0.25rem;
	}
	.diy-total-red { color: #f87171; }
	.diy-total-green { color: var(--brand); }
	.diy-total-sub {
		display: block; font-size: 0.8rem; color: var(--text-faint); line-height: 1.5;
	}

	/* ── TEAMS ───────────────────── */
	.teams { padding: 6rem 0; border-top: 1px solid var(--border); }

	.teams-grid {
		display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
		background: var(--border); border: 1px solid var(--border); border-radius: 12px;
		overflow: hidden;
	}
	.team-card {
		background: var(--bg); padding: 1.75rem;
		transition: background .2s;
	}
	.team-card:hover { background: var(--bg-card); }
	.tc-icon {
		width: 2.25rem; height: 2.25rem; border-radius: 8px;
		display: grid; place-items: center; margin-bottom: 0.85rem;
		background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.1);
	}
	.team-card h4 {
		font-size: 0.95rem; font-weight: 700; margin-bottom: 0.4rem;
		letter-spacing: -0.01em;
	}
	.team-card p { font-size: 0.85rem; line-height: 1.6; color: var(--text-dim); }

	/* ── SOCIAL / TESTIMONIALS ──── */
	.social { padding: 6rem 0; border-top: 1px solid var(--border); }

	.social-grid {
		display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
	}
	.quote-card {
		padding: 1.5rem; border: 1px solid var(--border); border-radius: 12px;
		background: var(--bg-card); transition: border-color .2s;
		display: flex; flex-direction: column;
	}
	.quote-card:hover { border-color: var(--border-bright); }
	.quote-card p {
		font-size: 0.9rem; line-height: 1.65; color: var(--text-dim);
		font-style: italic; flex: 1; margin-bottom: 1.25rem;
	}
	.quote-author {
		display: flex; align-items: center; gap: 0.65rem;
		padding-top: 1rem; border-top: 1px solid var(--border);
	}
	.quote-avatar {
		width: 2rem; height: 2rem; border-radius: 50%;
		background: rgba(74,222,128,0.1); color: var(--brand);
		display: grid; place-items: center; font-weight: 700;
		font-size: 0.78rem; flex-shrink: 0;
	}
	.quote-author strong {
		display: block; font-size: 0.82rem; font-weight: 600;
	}
	.quote-author span {
		display: block; font-size: 0.72rem; color: var(--text-faint);
	}

	/* ── AUTHOR ──────────────────── */
	.author { padding: 6rem 0; border-top: 1px solid var(--border); }

	.au-outer {
		display: grid; grid-template-columns: 340px 1fr; gap: 0;
		border: 1px solid var(--border); border-radius: 16px;
		overflow: hidden; background: var(--bg-card);
		max-width: 56rem; margin: 0 auto;
		align-items: stretch;
	}

	/* image column */
	.au-img-col {
		position: relative;
		background: linear-gradient(180deg, rgba(74,222,128,0.04), var(--bg-card));
		overflow: hidden;
	}
	.au-img {
		position: absolute !important; inset: 0 !important;
		width: 100% !important; height: 100% !important;
		max-width: none !important; max-height: none !important;
		object-fit: cover !important; object-position: center top !important;
		display: block !important;
	}

	/* body */
	.au-body {
		padding: 2.5rem 3rem;
		display: flex; flex-direction: column; justify-content: center;
	}

	.au-meta {
		display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem;
	}
	.au-tag {
		font-family: var(--mono); font-size: 0.68rem; font-weight: 600;
		text-transform: uppercase; letter-spacing: 0.1em; color: var(--brand);
	}
	.au-mvp {
		display: inline-flex; align-items: center; gap: 0.3rem;
		font-family: var(--mono); font-size: 0.65rem; font-weight: 600;
		color: #fbbf24; background: rgba(251,191,36,0.08);
		border: 1px solid rgba(251,191,36,0.12);
		padding: 0.15rem 0.5rem; border-radius: 4px;
	}

	.au-name {
		font-size: 1.6rem; font-weight: 600; letter-spacing: -0.03em;
		margin-bottom: 0.2rem;
	}
	.au-role {
		font-size: 0.88rem; color: var(--text-faint); margin-bottom: 1rem;
	}
	.au-bio {
		font-size: 0.9rem; line-height: 1.7; color: var(--text-dim);
		max-width: 34rem; margin-bottom: 1.5rem;
	}
	.au-bio a {
		color: var(--brand); text-decoration: underline;
		text-decoration-color: rgba(74,222,128,0.3);
		text-underline-offset: 2px;
	}
	.au-bio a:hover { text-decoration-color: var(--brand); }

	/* stats in bordered cells */
	.au-nums {
		display: flex; gap: 0; margin-bottom: 1.5rem;
		border: 1px solid var(--border); border-radius: 8px;
		overflow: hidden; width: fit-content;
	}
	.au-n {
		font-size: 0.78rem; color: var(--text-faint);
		padding: 0.55rem 1.1rem; text-align: center;
		border-right: 1px solid var(--border);
	}
	.au-n:last-child { border-right: 0; }
	.au-nv {
		display: block; font-weight: 600; color: var(--text);
		font-variant-numeric: tabular-nums; font-size: 1rem;
		margin-bottom: 0.05rem;
	}

	/* social icons */
	.au-socials { display: flex; gap: 0.25rem; }
	.au-socials a {
		display: grid; place-items: center;
		width: 2.25rem; height: 2.25rem; border-radius: 8px;
		color: var(--text-faint);
		transition: color .15s, background .15s;
	}
	.au-socials a:hover {
		color: var(--brand); background: rgba(74,222,128,0.06);
	}

	@media (max-width: 768px) {
		.au-outer { grid-template-columns: 1fr; }
		.au-img-col { width: 100%; height: 240px; }
		.au-body { padding: 1.75rem 1.5rem; }
		.au-nums { gap: 1rem; }
	}

	/* ── FAQ ──────────────────────── */
	.faq { padding: 6rem 0; border-top: 1px solid var(--border); }

	.faq-list {
		max-width: 42rem; margin: 0 auto;
		display: flex; flex-direction: column; gap: 0;
	}
	.faq-item {
		border-bottom: 1px solid var(--border);
	}
	.faq-item:first-child {
		border-top: 1px solid var(--border);
	}
	.faq-item summary {
		padding: 1.15rem 0; font-size: 0.95rem; font-weight: 600;
		cursor: pointer; list-style: none; display: flex; align-items: center;
		justify-content: space-between; color: var(--text);
		transition: color .15s;
	}
	.faq-item summary::-webkit-details-marker { display: none; }
	.faq-item summary::after {
		content: '+'; font-size: 1.1rem; font-weight: 400; color: var(--text-faint);
		flex-shrink: 0; margin-left: 1rem; transition: transform .2s;
	}
	.faq-item[open] summary::after {
		content: '+';
	}
	.faq-item summary:hover { color: var(--brand); }
	.faq-item p {
		font-size: 0.88rem; line-height: 1.7;
		color: var(--text-dim);
	}

	/* ── SCROLL REVEAL ───────────── */
	/*  Only opacity + translate3d = GPU composited, no layout/paint */
	[data-reveal] {
		opacity: 0;
		transform: translate3d(0, 20px, 0);
		transition: opacity 0.8s ease-out,
					transform 0.8s ease-out;
		will-change: opacity, transform;
	}
	[data-reveal].visible {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}

	/* staggered children */
	[data-reveal-stagger] > * {
		opacity: 0;
		transform: translate3d(0, 14px, 0);
		transition: opacity 0.7s ease-out,
					transform 0.7s ease-out;
		will-change: opacity, transform;
	}
	[data-reveal-stagger].visible > * {
		opacity: 1;
		transform: translate3d(0, 0, 0);
	}
	[data-reveal-stagger].visible > *:nth-child(1) { transition-delay: 0ms; }
	[data-reveal-stagger].visible > *:nth-child(2) { transition-delay: 80ms; }
	[data-reveal-stagger].visible > *:nth-child(3) { transition-delay: 160ms; }
	[data-reveal-stagger].visible > *:nth-child(4) { transition-delay: 230ms; }
	[data-reveal-stagger].visible > *:nth-child(5) { transition-delay: 300ms; }
	[data-reveal-stagger].visible > *:nth-child(6) { transition-delay: 360ms; }

	/* ── HERO GLOW BREATHING ─────── */
	.hero-glow {
		animation: glow-breathe 5s ease-in-out infinite;
		will-change: opacity, transform;
	}
	@keyframes glow-breathe {
		0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
		50% { opacity: 1; transform: translateX(-50%) scale(1.06); }
	}

	/* ── TERMINAL TYPING ─────────── */
	/* clip-path is GPU composited, unlike width */
	.ht-line[data-type] {
		white-space: nowrap;
		clip-path: inset(0 100% 0 0);
		opacity: 1;
		transition: clip-path 0.5s ease-out;
	}
	.ht-line[data-type].typed {
		clip-path: inset(0 0 0 0);
	}
	/* output lines: fade in */
	.ht-line.ht-out[data-type] {
		clip-path: none;
		opacity: 0;
		transform: translate3d(0, 3px, 0);
		transition: opacity 0.45s ease-out, transform 0.45s ease-out;
	}
	.ht-line.ht-out[data-type].typed {
		opacity: 0.6;
		transform: translate3d(0, 0, 0);
	}

	/* ── CARD HOVER LIFT ─────────── */
	/* translate3d forces GPU layer, separate shadow on pseudo to avoid paint */
	.b-card, .quote-card, .team-card, .diy-card {
		position: relative;
	}
	@media (min-width: 769px) {
		.b-card:not(.b-span2),
