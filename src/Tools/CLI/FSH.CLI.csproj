<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace>FSH.CLI</RootNamespace>
    <AssemblyName>FSH.CLI</AssemblyName>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>fsh</ToolCommandName>
    <PackageId>FullStackHero.CLI</PackageId>
    <Description>CLI tool for scaffolding and managing FullStackHero .NET projects.</Description>
    <PackageIcon>icon.png</PackageIcon>
    <!-- The CLI exposes no public API surface; an empty XML doc file is dead weight. -->
    <GenerateDocumentationFile>false</GenerateDocumentationFile>

    <!-- Strip pre-release suffix for AssemblyVersion (requires major.minor.build.revision format) -->
    <AssemblyVersion>10.0.0.0</AssemblyVersion>
    <FileVersion>10.0.0.0</FileVersion>

    <!-- Trim for smaller tool size -->
    <PublishTrimmed>false</PublishTrimmed>
    <SuppressTrimAnalysisWarnings>true</SuppressTrimAnalysisWarnings>

    <!-- Suppress analyzer noise for CLI tool:
         CA1031 = catch general exceptions (acceptable for CLI best-effort operations)
         CA1515 = types can be internal (Spectre.Console.Cli requires public commands)
         S1075  = hardcoded URIs (URLs are constants, not configurable paths) -->
    <NoWarn>$(NoWarn);CA1031;CA1515;S1075</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Spectre.Console" />
    <PackageReference Include="Spectre.Console.Cli" />
  </ItemGroup>

  <ItemGroup>
    <!-- Gallery icon for the published tool package. -->
    <None Include="..\..\..\.template.config\icon.png" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>

</Project>
