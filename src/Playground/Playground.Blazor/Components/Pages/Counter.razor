@page "/counter"
@using FSH.Playground.Blazor.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<PlaygroundResource> PL

<PageTitle>@PL["Counter"]</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">@PL["Counter"]</MudText>

<MudText Typo="Typo.body1" Class="mb-4">@PL["CurrentCount"]: @currentCount</MudText>

<MudButton Color="Color.Primary" Variant="Variant.Filled" @onclick="IncrementCount">@PL["ClickMe"]</MudButton>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
